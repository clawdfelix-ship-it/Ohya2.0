<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <!-- 導航欄 -->
  <nav class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <a href="/" class="flex items-center space-x-2">
          <span class="text-2xl">🛍️</span>
          <span class="text-xl font-bold text-gray-900">Ohya2.0</span>
        </a>
        
        <div class="flex items-center space-x-8">
          <a href="/" class="text-gray-700 hover:text-blue-600 font-medium">首頁</a>
          <a href="/products" class="text-gray-700 hover:text-blue-600 font-medium">全部商品</a>
          <a href="/cart" class="text-gray-700 hover:text-blue-600 font-medium flex items-center gap-1">
            🛒 購物車 <span class="bg-blue-100 text-blue-600 text-xs px-2 py-1 rounded-full" id="cart-count">0</span>
          </a>
          
          <% if (user) { %>
            <div class="flex items-center gap-3">
              <span class="text-gray-600">👋 歡迎</span>
              <a href="/logout" class="text-red-600 hover:text-red-700 font-medium">登出</a>
            </div>
          <% } else { %>
            <a href="/login" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 font-medium">登入</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Banner -->
  <div class="bg-gradient-to-r from-blue-600 to-purple-600 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">🛍️ Ohya2.0 電商平台</h1>
      <p class="text-xl text-blue-100 mb-8">發掘優質商品，享受便捷購物體驗</p>
      <a href="/products" class="bg-white text-blue-600 px-8 py-3 rounded-lg font-bold text-lg hover:bg-gray-100 transition inline-block">
        開始購物 →
      </a>
    </div>
  </div>

  <!-- 分類標籤 -->
  <% if (categories && categories.length > 0) { %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-wrap gap-3 justify-center">
        <% categories.forEach(category => { %>
          <a href="/products?category=<%= category.id %>" class="bg-white px-5 py-2 rounded-full shadow-sm hover:shadow-md transition text-gray-700 font-medium">
            <%= category.name %>
          </a>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- 精選商品 -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">🔥 精選商品</h2>
    
    <% if (products && products.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% products.forEach(product => { %>
          <a href="/product/<%= product.id %>" class="bg-white rounded-xl shadow-sm hover:shadow-lg transition duration-300 overflow-hidden group">
            <div class="aspect-square bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center relative overflow-hidden">
              <% if (product.originalPrice && product.originalPrice > product.price) { %>
                <span class="absolute top-3 left-3 bg-red-500 text-white text-xs px-2 py-1 rounded-full font-bold z-10">
                  -<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%
                </span>
              <% } %>
              <% if (product.image) { %>
                <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
              <% } else { %>
                <span class="text-6xl group-hover:scale-110 transition duration-300">📦</span>
              <% } %>
            </div>
            <div class="p-4">
              <span class="text-xs text-blue-600 font-medium bg-blue-50 px-2 py-1 rounded-full"><%= product.category %></span>
              <h3 class="font-semibold text-gray-900 mt-2 mb-2 group-hover:text-blue-600 transition line-clamp-2 h-12"><%= product.name %></h3>
              <p class="text-sm text-gray-500 mb-3 line-clamp-2 h-10"><%= product.description || '優質商品' %></p>
              <div class="flex items-center justify-between">
                <div>
                  <span class="text-xl font-bold text-blue-600"><%= formatPrice(product.price) %></span>
                  <% if (product.originalPrice && product.originalPrice > product.price) { %>
                    <span class="text-sm text-gray-400 line-through ml-2"><%= formatPrice(product.originalPrice) %></span>
                  <% } %>
                </div>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-16 bg-white rounded-xl">
        <span class="text-6xl mb-4 block">📦</span>
        <p class="text-gray-500">暫未有商品，敬請期待！</p>
      </div>
    <% } %>
  </div>

  <!-- 頁腳 -->
  <footer class="bg-gray-900 text-white py-12 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <h3 class="text-lg font-bold mb-4">🛍️ Ohya2.0</h3>
          <p class="text-gray-400">全功能電商平台，為你提供最優質嘅購物體驗。</p>
        </div>
        <div>
          <h3 class="text-lg font-bold mb-4">快速連結</h3>
          <ul class="space-y-2 text-gray-400">
            <li><a href="/" class="hover:text-white transition">首頁</a></li>
            <li><a href="/products" class="hover:text-white transition">全部商品</a></li>
            <li><a href="/cart" class="hover:text-white transition">購物車</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-bold mb-4">客戶服務</h3>
          <ul class="space-y-2 text-gray-400">
            <li>📧 support@ohya20.com</li>
            <li>📞 +852 1234 5678</li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-500">
        © 2026 Ohya2.0. All rights reserved.
      </div>
    </div>
  </footer>

  <script>
    // 購物車計數
    function updateCartCount() {
      const cart = JSON.parse(localStorage.getItem('cart') || '[]');
      const count = cart.reduce((sum, item) => sum + item.quantity, 0);
      document.getElementById('cart-count').textContent = count;
    }
    updateCartCount();
  </script>
</body>
</html>
