<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Noto Sans TC', sans-serif;
    }
    .jpn-bracket::before { content: '【'; }
    .jpn-bracket::after { content: '】'; }
    .product-grid {
      gap: 0.75rem;
    }
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .modal-animate {
      animation: slideDown 0.3s ease-out;
    }
  </style>
</head>
<body class="bg-white text-black min-h-screen">

  <!-- 年齡確認 -->
  <div id="ageModal" class="fixed inset-0 bg-black/80 z-[100] flex items-center justify-center hidden">
    <div class="modal-animate bg-white rounded-lg p-8 max-w-md w-full mx-4 text-center shadow-2xl">
      <div class="text-5xl mb-4">🔞</div>
      <h2 class="text-2xl font-bold mb-4"><%= t('age.title') %></h2>
      <p class="text-gray-600 mb-6 whitespace-pre-line"><%= t('age.desc') %></p>
      <div class="flex gap-4 justify-center">
        <button onclick="verifyAge(true)" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-10 rounded-lg transition text-lg">
          <%= t('common.yes') %>
        </button>
        <button onclick="verifyAge(false)" class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold py-3 px-10 rounded-lg transition text-lg">
          <%= t('common.no') %>
        </button>
      </div>
      <p class="text-xs text-gray-400 mt-6">
        選擇「否」將無法繼續瀏覽本網站。
      </p>
    </div>
  </div>

  <!-- 頁首 -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <!-- 頂部提示 -->
    <div class="bg-gray-900 text-white text-xs py-1">
      <div class="max-w-7xl mx-auto px-2 flex justify-between items-center">
        <span class="text-orange-400 font-bold">【積分 5 倍】註冊會員更抵！</span>
        <div class="hidden sm:flex gap-4">
          <a href="#" class="hover:text-orange-400"><%= t('nav.myAccount') %></a>
          <a href="#" class="hover:text-orange-400"><%= t('nav.faq') %></a>
          <a href="#" class="hover:text-orange-400"><%= t('nav.contact') %></a>
        </div>
      </div>
    </div>
    
    <!-- Main Header -->
    <div class="max-w-7xl mx-auto px-2 py-3">
      <div class="flex items-center justify-between gap-4">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 flex-shrink-0">
          <span class="text-3xl">🏪</span>
          <span class="text-xl font-black text-red-600">OHYA2.0</span>
        </a>
        
        <!-- 搜尋 -->
        <div class="hidden md:flex flex-1 max-w-xl">
          <div class="flex">
            <input type="text" placeholder="<%= t('nav.searchPlaceholder') %>" class="flex-1 border-2 border-gray-300 rounded-l-lg px-4 py-2 text-sm focus:border-red-500 focus:outline-none">
            <button class="bg-red-600 text-white px-6 rounded-r-lg hover:bg-red-700 transition font-bold">
              <%= t('nav.search') %>
            </button>
          </div>
        </div>
        <!-- Mobile Search Button -->
        <button class="md:hidden text-xl">🔍</button>
        
        <!-- 購物車與帳戶 -->
        <div class="flex items-center gap-4 flex-shrink-0">
          <a href="/cart" class="flex items-center gap-1 text-sm hover:text-red-600 transition">
            <span class="text-xl">🛒</span>
            <span><%= t('nav.cart') %></span>
            <span class="bg-red-600 text-white text-xs px-2 py-0.5 rounded-full font-bold" id="cart-count">0</span>
          </a>
          <% if (user) { %>
            <div class="text-sm">
              <span class="text-gray-600">歡迎</span>
              <a href="/logout" class="text-red-600 hover:underline ml-2">登出</a>
            </div>
          <% } else { %>
            <a href="/login" class="text-sm hover:text-red-600 transition"><%= t('nav.login') %></a>
            <a href="/register" class="bg-red-600 text-white text-sm px-4 py-1.5 rounded hover:bg-red-700 transition font-bold"><%= t('nav.register') %></a>
          <% } %>
        </div>
      </div>
    </div>
    
    <!-- 分類導航 -->
    <nav class="bg-gray-100 border-t border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-2">
        <div class="flex items-center gap-0">
          <!-- Category Dropdown -->
          <div class="relative group flex-shrink-0">
            <button class="bg-red-600 text-white px-3 py-2.5 font-bold text-sm flex items-center gap-1 hover:bg-red-700 transition">
              <span>☰</span>
              <span class="hidden sm:inline">商品分類</span>
              <span class="hidden md:inline">▼</span>
            </button>
            <div class="absolute left-0 top-full bg-white shadow-xl border border-gray-200 w-64 hidden group-hover:block z-50">
              <% categories.forEach(cat => { %>
                <a href="/products?category=<%= cat.name %>" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 border-b border-gray-100">
                  <%= cat.name %> <span class="text-gray-400">(<%= cat.count %>)</span>
                </a>
              <% }) %>
            </div>
          </div>
          
          <!-- Quick Category Links -->
          <div class="flex overflow-x-auto no-scrollbar flex-1">
            <a href="/products?category=男士護理" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">男士護理</a>
            <a href="/products?category=護理配件" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">護理配件</a>
            <a href="/products?category=進階系列" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">進階系列</a>
            <a href="/products?category=頂級系列" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">頂級系列</a>
            <a href="/products?category=優惠套裝" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">優惠套裝</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">最新上架</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">人氣排行榜</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">限時優惠</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">品牌一覽</a>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <!-- OHYA2.0 Classic 3-Column Wrapper -->
  <div id="wrapper" class="max-w-7xl mx-auto px-2 mt-4 mb-4 flex gap-4 flex-col lg:flex-row">
    
    <!-- LEFT SIDEBAR - Category Menu -->
    <div id="wrap_left" class="lg:w-52 flex-shrink-0 order-2 lg:order-1">
      <div id="menu" class="bg-white border border-gray-200 rounded-lg overflow-hidden">
        <h3 onclick="toggleCategories()" class="bg-[#ba0000] text-white font-bold px-4 py-2 text-sm cursor-pointer flex justify-between items-center lg:cursor-default">
          <span>【商品分類】</span>
          <span id="catToggle" class="lg:hidden">▼</span>
        </h3>
        <ul id="catList" class="divide-y divide-gray-100 hidden lg:block">
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">🆕 新商品・新規取扱商品</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">✨ OHYA2.0 原創</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">🧴 潤滑液・清潔劑</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">💪 飛機杯・巨乳</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">🛌 抱枕・娃娃</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">🔌 震動棒・電動按摩棒</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">🌀 跳蛋・乳頭刺激</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">🛡️ 安全套</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">🍑 後庭用品</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">🔧 輔助工具</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">⛓️ SM・拘束具</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">💊 保健品・香水</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">👗 角色扮演</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">📚 書籍・雜貨</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition">🏪 營業用</a></li>
          <li><a href="/products?category=男士護理" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 transition text-red-600 font-bold">🔥 大減價 SALE!</a></li>
        </ul>
      </div>
      
      <!-- Left Side Ad -->
      <div class="mt-4 bg-gradient-to-r from-red-500 to-orange-500 text-white rounded-lg p-4 text-center">
        <h4 class="font-bold text-sm mb-1">【本日限定】</h4>
        <p class="text-xl font-black">超特價！</p>
        <p class="text-xs opacity-90">最大 70% OFF</p>
      </div>
    </div>
    
    <!-- MAIN CONTENT CENTER -->
    <div id="wrap_center" class="flex-1 order-1 lg:order-2">
      <!-- Main Banner Carousel -->
      <div class="relative rounded-lg overflow-hidden mb-3">
        <div id="bannerCarousel" class="flex transition-transform duration-500">
          <div class="min-w-full">
            <img src="/images/105de4b0f17941cd79fb7b0572340d95.jpg" alt="OHYA2.0 Banner 1" class="w-full h-48 sm:h-64 md:h-72 lg:h-80 object-cover">
          </div>
          <div class="min-w-full">
            <img src="/images/2d6af70828e32ec6381b2b81900fa4d2.jpg" alt="OHYA2.0 Banner 2" class="w-full h-48 sm:h-64 md:h-72 lg:h-80 object-cover">
          </div>
          <div class="min-w-full">
            <img src="/images/a63d52684e4989d093d0748870f93058.jpg" alt="OHYA2.0 Banner 3" class="w-full h-48 sm:h-64 md:h-72 lg:h-80 object-cover">
          </div>
        </div>
        <button onclick="moveBanner(-1)" class="absolute left-2 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white w-10 h-10 rounded-full flex items-center justify-center transition">❮</button>
        <button onclick="moveBanner(1)" class="absolute right-2 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white w-10 h-10 rounded-full flex items-center justify-center transition">❯</button>
        <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2">
          <button onclick="gotoBanner(0)" class="banner-dot w-2.5 h-2.5 rounded-full bg-white/80 transition"></button>
          <button onclick="gotoBanner(1)" class="banner-dot w-2.5 h-2.5 rounded-full bg-white/50 transition"></button>
          <button onclick="gotoBanner(2)" class="banner-dot w-2.5 h-2.5 rounded-full bg-white/50 transition"></button>
        </div>
      </div>
      
      <!-- Stacked Sub Banners -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
        <div class="bg-gray-900 text-white rounded-lg p-4">
          <h3 class="font-bold text-orange-400 jpn-bracket text-sm">會員限定</h3>
          <p class="text-lg font-bold mt-1">每月送積分</p>
          <p class="text-xs text-gray-400 mt-1">按會員等級派發積分</p>
        </div>
        <div class="bg-red-50 border-2 border-red-500 rounded-lg p-4">
          <h3 class="font-bold text-red-600 jpn-bracket text-sm">售完即止</h3>
          <p class="text-lg font-bold mt-1 text-red-600">最多 50% OFF</p>
          <p class="text-xs text-gray-600 mt-1">熱門商品大量售罄中！</p>
        </div>
        <div class="bg-blue-50 border border-blue-300 rounded-lg p-4">
          <h3 class="font-bold text-blue-600 jpn-bracket text-sm">免運費</h3>
          <p class="text-lg font-bold mt-1 text-blue-600">滿 ¥3,000</p>
          <p class="text-xs text-gray-600 mt-1">全區配送免運</p>
        </div>
      </div>
      
      <!-- 配送提示 -->
      <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <span class="text-2xl">📅</span>
            <div>
              <h3 class="font-bold text-sm">【可指定送貨時段】</h3>
              <p class="text-xs text-gray-600">可按你選擇的日期時間送達</p>
            </div>
          </div>
          <div class="flex gap-2 text-xs">
            <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full font-bold">即日出貨</span>
            <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full font-bold">最快明天到</span>
            <span class="bg-purple-100 text-purple-700 px-3 py-1 rounded-full font-bold">可選時段</span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- RIGHT SIDEBAR - Desktop Only -->
    <div id="wrap_right" class="lg:w-48 flex-shrink-0 order-3 hidden lg:block">
      <div id="menu_right" class="bg-white border border-gray-200 rounded-lg overflow-hidden mb-4">
        <h3 class="bg-gray-800 text-white font-bold px-4 py-2 text-sm">【最近睇過】</h3>
        <div class="p-3 text-center text-gray-400 text-xs">
          <p>仲冇瀏覽記錄</p>
          <p class="mt-1">開始睇吓商品啦！</p>
        </div>
      </div>
      
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden mb-4">
        <h3 class="bg-orange-500 text-white font-bold px-4 py-2 text-sm">【人氣商品】</h3>
        <ul class="divide-y divide-gray-100">
          <li><a href="#" class="block px-3 py-2 text-xs hover:bg-orange-50 hover:text-orange-600 transition">🔥 本週熱賣 No.1</a></li>
          <li><a href="#" class="block px-3 py-2 text-xs hover:bg-orange-50 hover:text-orange-600 transition">⭐ 好評推薦</a></li>
          <li><a href="#" class="block px-3 py-2 text-xs hover:bg-orange-50 hover:text-orange-600 transition">💎 會員獨享</a></li>
          <li><a href="#" class="block px-3 py-2 text-xs hover:bg-orange-50 hover:text-orange-600 transition">🆕 新上架</a></li>
        </ul>
      </div>
      
      <!-- Right Side Ad -->
      <div class="bg-gradient-to-b from-yellow-100 to-orange-100 rounded-lg p-3 text-center border border-orange-200">
        <h4 class="font-bold text-orange-600 text-xs mb-1">【初回限定】</h4>
        <p class="text-sm font-bold text-orange-700">首次購物</p>
        <p class="text-xs text-orange-600">送 ¥500 優惠券</p>
      </div>
    </div>
    
  </div>
  <!-- END OHYA2.0 3-Column Wrapper -->

  <!-- 商品列表 - 跨三欄全闊 -->

  <!-- 人氣商品 -->
  <div class="max-w-7xl mx-auto px-2 py-6">
    <h2 class="text-2xl font-black mb-6 jpn-bracket inline-block"><%= t('home.featured') %></h2>
    <span class="text-sm text-gray-500 ml-2">— 精選高評價商品 —</span>
    
    <% if (products && products.length > 0) { %>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 product-grid mt-4">
        <% products.forEach(product => { %>
          <div class="bg-white border border-gray-200 rounded-lg hover:shadow-lg transition duration-300 overflow-hidden group">
            <a href="/product/<%= product.id %>" class="block">
              <div class="aspect-square bg-gray-50 relative overflow-hidden">
                <!-- Badges -->
                <div class="absolute top-2 left-2 z-10 flex flex-col gap-1">
                  <% if (product.originalPrice && product.originalPrice > product.price) { %>
                    <span class="bg-red-600 text-white text-xs px-2 py-1 rounded font-bold">
                      <%= t('product.badge.deal') %>
                    </span>
                    <span class="bg-orange-500 text-white text-xs px-2 py-1 rounded font-bold">
                      -<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%OFF
                    </span>
                  <% } %>
                  <% if (product.stock <= 20) { %>
                    <span class="bg-yellow-500 text-black text-xs px-2 py-1 rounded font-bold">
                      <%= t('product.badge.lowStock') %>
                    </span>
                  <% } %>
                </div>
                <% if (product.image) { %>
                  <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center text-6xl bg-gradient-to-br from-gray-100 to-gray-200">📦</div>
                <% } %>
              </div>
              <div class="p-3">
                <span class="text-xs text-red-600 font-bold bg-red-50 px-2 py-0.5 rounded"><%= product.category %></span>
                <h3 class="font-medium text-sm mt-2 mb-2 line-clamp-2 h-10 leading-tight"><%= product.name %></h3>
                
                <!-- Price Display -->
                <div class="mb-3">
                  <span class="text-xl font-black text-red-600"><%= formatPrice(product.price) %></span>
                  <% if (product.originalPrice && product.originalPrice > product.price) { %>
                    <span class="text-xs text-gray-400 line-through ml-1"><%= formatPrice(product.originalPrice) %></span>
                  <% } %>
                </div>
                
                <!-- Points Display -->
                <div class="text-xs text-red-600 mb-3">
                  <span class="font-bold">積分：<%= Math.floor(product.price / 100) %>pt</span>
                  <span class="text-gray-400">（1 倍）</span>
                </div>
                
                <!-- CTAs -->
                <div class="flex gap-2">
                  <a href="/product/<%= product.id %>" class="flex-1 bg-red-600 hover:bg-red-700 text-white text-center py-2 rounded font-bold text-xs transition">
                    <%= t('product.cta.details') %>
                  </a>
                  <button onclick="addToCart(this)" data-product-id="<%= product.id %>" class="bg-orange-500 hover:bg-orange-600 text-white px-3 py-2 rounded font-bold text-xs transition">
                    🛒
                  </button>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
      
      <div class="text-center mt-8">
        <a href="/products" class="inline-block bg-gray-900 hover:bg-black text-white font-bold py-3 px-12 rounded-lg transition">
          <%= t('home.viewAll') %>
        </a>
      </div>
    <% } %>
  </div>

  <!-- 品牌 -->
  <div class="bg-gray-50 py-8 mt-4">
    <div class="max-w-7xl mx-auto px-2">
      <h2 class="text-xl font-black mb-6 jpn-bracket inline-block">合作品牌</h2>
      <div class="grid grid-cols-6 gap-4">
        <% ['PRO-E', 'MASTER-E', '狂也', "MEN'S MANZOKU", 'EXE', '對子哈特'].forEach(brand => { %>
          <div class="bg-white border border-gray-200 rounded-lg p-4 text-center hover:border-red-300 transition cursor-pointer">
            <span class="font-bold text-gray-700"><%= brand %></span>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- 頁尾 -->
  <footer class="bg-gray-900 text-white mt-8">
    <div class="max-w-7xl mx-auto px-2 py-10">
      <!-- 連結 -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6 mb-8">
        <div>
          <h4 class="font-bold mb-4 text-sm">【使用指南】</h4>
          <ul class="space-y-2 text-xs text-gray-400">
            <li><a href="#" class="hover:text-white transition">訂購方法</a></li>
            <li><a href="#" class="hover:text-white transition">付款方式</a></li>
            <li><a href="#" class="hover:text-white transition">配送安排</a></li>
