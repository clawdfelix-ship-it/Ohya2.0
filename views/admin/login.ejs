<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/mzakka-theme.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="mz-body text-black min-h-screen">
  <div class="max-w-lg mx-auto mt-10 px-3">
    <div class="mz-wrapper border border-gray-300 bg-white p-5">
      <div class="text-lg font-black mb-4">後台登入</div>

      <% if (error) { %>
        <div class="mb-3 p-2 border border-red-300 bg-red-50 text-red-700 text-sm"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/login" class="space-y-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
        <div>
          <label class="block text-sm font-bold mb-1" for="username">用戶名</label>
          <input id="username" name="username" class="w-full border border-gray-300 px-3 py-2" autocomplete="username" required>
        </div>
        <div>
          <label class="block text-sm font-bold mb-1" for="password">密碼</label>
          <input id="password" name="password" type="password" class="w-full border border-gray-300 px-3 py-2" autocomplete="current-password" required>
        </div>
        <button class="w-full bg-black text-white py-2 font-bold">登入</button>
      </form>

      <div class="text-xs text-gray-600 mt-4">
        如果你未建立管理員，請先到 <a href="/admin/setup" class="underline">後台初始化</a>
      </div>
    </div>
  </div>
</body>
</html>
