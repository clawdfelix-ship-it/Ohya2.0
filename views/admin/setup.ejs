<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/mzakka-theme.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="mz-body text-black min-h-screen">
  <div class="max-w-lg mx-auto mt-10 px-3">
    <div class="mz-wrapper border border-gray-300 bg-white p-5">
      <div class="text-lg font-black mb-2">後台初始化</div>
      <div class="text-sm text-gray-600 mb-4">只可用一次：建立第一個管理員帳號後，呢頁會自動封鎖。</div>

      <form method="POST" action="/admin/setup" class="space-y-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
        <div>
          <label class="block text-sm font-bold mb-1" for="username">管理員用戶名</label>
          <input id="username" name="username" class="w-full border border-gray-300 px-3 py-2" autocomplete="username" required>
        </div>
        <div>
          <label class="block text-sm font-bold mb-1" for="password">密碼（至少 6 位）</label>
          <input id="password" name="password" type="password" class="w-full border border-gray-300 px-3 py-2" autocomplete="new-password" required>
        </div>
        <div>
          <label class="block text-sm font-bold mb-1" for="contact">聯絡方式（可選）</label>
          <input id="contact" name="contact" class="w-full border border-gray-300 px-3 py-2" autocomplete="off">
        </div>
        <button class="w-full bg-black text-white py-2 font-bold">建立管理員</button>
      </form>

      <div class="text-xs text-gray-600 mt-4">
        已有管理員？請到 <a href="/admin/login" class="underline">後台登入</a>
      </div>
    </div>
  </div>
</body>
</html>
