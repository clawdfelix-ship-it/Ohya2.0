<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center">
  <div class="max-w-md w-full bg-white rounded-2xl shadow-lg p-8">
    <div class="text-center mb-8">
      <span class="text-5xl mb-4 block">🛍️</span>
      <h1 class="text-2xl font-bold text-gray-900 mb-2">登入帳戶</h1>
      <p class="text-gray-500">歡迎返到 Ohya2.0</p>
    </div>
    
    <form action="/api/auth/login" method="POST" class="space-y-4">
      <div>
        <label class="block text-gray-700 font-medium mb-2">用戶名</label>
        <input type="text" name="username" required class="w-full px-4 py-3 border rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="輸入用戶名">
      </div>
      
      <div>
        <label class="block text-gray-700 font-medium mb-2">密碼</label>
        <input type="password" name="password" required class="w-full px-4 py-3 border rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="輸入密碼">
      </div>
      
      <button type="submit" class="w-full bg-blue-600 text-white py-4 rounded-xl font-bold text-lg hover:bg-blue-700 transition">
        登入
      </button>
    </form>
    
    <div class="mt-6 text-center">
      <p class="text-gray-500">
        仲未有帳戶？
        <a href="/register" class="text-blue-600 font-medium hover:underline">立即註冊</a>
      </p>
    </div>
    
    <div class="mt-8 text-center">
      <a href="/" class="text-gray-400 hover:text-gray-600">← 返回首頁</a>
    </div>
  </div>
</body>
</html>
