<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Noto Sans JP', sans-serif;
    }
    .jpn-bracket::before { content: '【'; }
    .jpn-bracket::after { content: '】'; }
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .modal-animate {
      animation: slideDown 0.3s ease-out;
    }
  </style>
</head>
<body class="bg-white text-black min-h-screen">

  <!-- 年齢確認モーダル / Age Verification Modal -->
  <div id="ageModal" class="fixed inset-0 bg-black/80 z-[100] flex items-center justify-center hidden">
    <div class="modal-animate bg-white rounded-lg p-8 max-w-md w-full mx-4 text-center shadow-2xl">
      <div class="text-5xl mb-4">🔞</div>
      <h2 class="text-2xl font-bold mb-4">年齢確認</h2>
      <p class="text-gray-600 mb-6">
        このサイトには成人向けの商品が含まれています。<br>
        18歳以上ですか？
      </p>
      <div class="flex gap-4 justify-center">
        <button onclick="verifyAge(true)" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-10 rounded-lg transition text-lg">
          はい
        </button>
        <button onclick="verifyAge(false)" class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold py-3 px-10 rounded-lg transition text-lg">
          いいえ
        </button>
      </div>
      <p class="text-xs text-gray-400 mt-6">
        ※「いいえ」をクリックすると、このサイトを閲覧できません。
      </p>
    </div>
  </div>

  <!-- ヘッダー / Header -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <!-- Top Bar -->
    <div class="bg-gray-900 text-white text-xs py-1">
      <div class="max-w-7xl mx-auto px-2 flex justify-between items-center">
        <span class="text-orange-400 font-bold">【ポイント5倍】会員登録でさらにお得！</span>
        <div class="flex gap-4">
          <a href="#" class="hover:text-orange-400">マイページ</a>
          <a href="#" class="hover:text-orange-400">よくある質問</a>
          <a href="#" class="hover:text-orange-400">お問い合わせ</a>
        </div>
      </div>
    </div>
    
    <!-- Main Header -->
    <div class="max-w-7xl mx-auto px-2 py-3">
      <div class="flex items-center justify-between gap-4">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 flex-shrink-0">
          <span class="text-3xl">🏪</span>
          <span class="text-xl font-black text-red-600">M-ZAKKA</span>
        </a>
        
        <!-- Search -->
        <div class="flex-1 max-w-xl">
          <div class="flex">
            <input type="text" placeholder="商品名・ブランドで検索" class="flex-1 border-2 border-gray-300 rounded-l-lg px-4 py-2 text-sm focus:border-red-500 focus:outline-none">
            <button class="bg-red-600 text-white px-6 rounded-r-lg hover:bg-red-700 transition font-bold">
              検索
            </button>
          </div>
        </div>
        
        <!-- Cart & Account -->
        <div class="flex items-center gap-4 flex-shrink-0">
          <a href="/cart" class="flex items-center gap-1 text-sm hover:text-red-600 transition">
            <span class="text-xl">🛒</span>
            <span>カート</span>
            <span class="bg-red-600 text-white text-xs px-2 py-0.5 rounded-full font-bold" id="cart-count">0</span>
          </a>
          <% if (user) { %>
            <div class="text-sm">
              <span class="text-gray-600">ようこそ</span>
              <a href="/logout" class="text-red-600 hover:underline ml-2">ログアウト</a>
            </div>
          <% } else { %>
            <a href="/login" class="text-sm hover:text-red-600 transition">ログイン</a>
            <a href="/register" class="bg-red-600 text-white text-sm px-4 py-1.5 rounded hover:bg-red-700 transition font-bold">新規登録</a>
          <% } %>
        </div>
      </div>
    </div>
    
    <!-- Category Navigation - Japanese Style Dense -->
    <nav class="bg-gray-100 border-t border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-2">
        <div class="flex items-center gap-0">
          <!-- Category Dropdown -->
          <div class="relative group">
            <button class="bg-red-600 text-white px-4 py-2.5 font-bold text-sm flex items-center gap-2 hover:bg-red-700 transition">
              <span>☰</span>
              商品カテゴリー
              <span>▼</span>
            </button>
            <div class="absolute left-0 top-full bg-white shadow-xl border border-gray-200 w-64 hidden group-hover:block z-50">
              <a href="/products?category=全部商品" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 border-b border-gray-100">
                全部商品
              </a>
              <a href="/products?category=メンズケア" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 border-b border-gray-100">
                メンズケア
              </a>
              <a href="/products?category=アクセサリー" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 border-b border-gray-100">
                アクセサリー
              </a>
              <a href="/products?category=アドバンス" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 border-b border-gray-100">
                アドバンス
              </a>
              <a href="/products?category=プレミアム" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 border-b border-gray-100">
                プレミアム
              </a>
              <a href="/products?category=お得セット" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 border-b border-gray-100">
                お得セット
              </a>
            </div>
          </div>
          
          <!-- Quick Category Links -->
          <div class="flex overflow-x-auto no-scrollbar flex-1">
            <a href="/products?category=メンズケア" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">メンズケア</a>
            <a href="/products?category=アクセサリー" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">アクセサリー</a>
            <a href="/products?category=アドバンス" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">アドバンス</a>
            <a href="/products?category=プレミアム" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">プレミアム</a>
            <a href="/products?category=お得セット" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">お得セット</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">新着商品</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">人気ランキング</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">タイムセール</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">ブランド一覧</a>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <!-- パンくずリスト / Breadcrumb -->
  <div class="max-w-7xl mx-auto px-2 py-3">
    <nav class="text-xs text-gray-500">
      <a href="/" class="hover:text-red-600">ホーム</a>
      <span class="mx-2">›</span>
      <a href="/products" class="hover:text-red-600">商品一覧</a>
      <span class="mx-2">›</span>
      <span class="text-red-600 font-medium"><%= product.name %></span>
    </nav>
  </div>

  <!-- 商品詳細 / Product Detail -->
  <div class="max-w-7xl mx-auto px-2 py-4">
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-6">
        <!-- 商品画像 -->
        <div class="aspect-square bg-gray-50 border border-gray-200 rounded-lg flex items-center justify-center p-8 relative">
          <% if (product.originalPrice && product.originalPrice > product.price) { %>
            <div class="absolute top-4 left-4 z-10">
              <span class="bg-red-600 text-white text-sm px-4 py-2 rounded-lg font-bold">
                お買い得商品
              </span>
            </div>
          <% } %>
          <% if (product.image) { %>
            <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-contain rounded-lg">
          <% } else { %>
            <span class="text-9xl">📦</span>
          <% } %>
        </div>
        
        <!-- 商品情報 -->
        <div class="flex flex-col">
          <span class="text-xs text-red-600 font-bold bg-red-50 px-3 py-1 rounded w-fit mb-3"><%= product.category %></span>
          <h1 class="text-2xl font-black text-gray-900 mb-4"><%= product.name %></h1>
          
          <!-- 価格表示 -->
          <div class="mb-6 bg-gray-50 p-4 rounded-lg">
            <div class="flex items-baseline gap-3">
              <span class="text-4xl font-black text-red-600"><%= formatPrice(product.price) %></span>
              <% if (product.originalPrice && product.originalPrice > product.price) { %>
                <span class="text-lg text-gray-400 line-through"><%= formatPrice(product.originalPrice) %></span>
                <span class="bg-red-100 text-red-600 px-3 py-1 rounded-lg text-sm font-bold">
                  <%= Math.round((1 - product.price / product.originalPrice) * 100) %>%OFF
                </span>
              <% } %>
            </div>
            <div class="mt-3 text-sm text-gray-600">
              <span class="text-red-600 font-bold">獲得ポイント：<%= Math.floor(product.price / 100) %>pt</span>
              <span class="text-gray-400 ml-2">(1倍)</span>
            </div>
          </div>
          
          <!-- 在庫情報 -->
          <div class="mb-4 flex items-center gap-4">
            <span class="text-sm">📦 在庫：</span>
            <% if (product.stock > 20) { %>
              <span class="font-bold text-green-600 bg-green-50 px-3 py-1 rounded text-sm">在庫あり</span>
            <% } else if (product.stock > 0) { %>
              <span class="font-bold text-orange-600 bg-orange-50 px-3 py-1 rounded text-sm">残りわずか（<%= product.stock %>点）</span>
            <% } else { %>
              <span class="font-bold text-gray-500 bg-gray-100 px-3 py-1 rounded text-sm">在庫切れ</span>
            <% } %>
          </div>
          
          <!-- 商品説明 -->
          <div class="border-t border-b py-4 mb-6">
            <h3 class="font-bold text-gray-900 mb-3 jpn-bracket">商品説明</h3>
            <p class="text-gray-600 leading-relaxed text-sm">
              <%= product.description || '高品質な製品をお届けします。' %>
            </p>
          </div>
          
          <!-- 購入エリア -->
          <div class="mt-auto space-y-4">
            <div class="flex items-center gap-4">
              <label class="text-gray-700 font-medium text-sm">数量：</label>
              <div class="flex items-center border border-gray-300 rounded-lg">
                <button onclick="changeQuantity(-1)" class="px-4 py-2 hover:bg-gray-100 transition font-bold">－</button>
                <input type="number" id="quantity" value="1" min="1" max="<%= product.stock %>" class="w-16 text-center border-x border-gray-300 py-2 focus:outline-none font-medium">
                <button onclick="changeQuantity(1)" class="px-4 py-2 hover:bg-gray-100 transition font-bold">＋</button>
              </div>
            </div>
            
            <div class="flex gap-3">
              <button onclick="addToCart()" class="flex-1 bg-red-600 text-white py-4 rounded-lg font-bold text-lg hover:bg-red-700 transition flex items-center justify-center gap-2">
                🛒 カートに入れる
              </button>
              <button class="bg-gray-100 text-gray-700 px-6 py-4 rounded-lg font-bold hover:bg-gray-200 transition">
                ❤️
              </button>
            </div>
            
            <div class="flex gap-3 text-xs">
              <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full font-medium">🚚 送料無料</span>
              <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full font-medium">📦 即日発送</span>
              <span class="bg-purple-100 text-purple-700 px-3 py-1 rounded-full font-medium">🔒 安全決済</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- 関連商品 -->
    <% if (relatedProducts && relatedProducts.length > 0) { %>
      <div class="mt-10">
        <h2 class="text-xl font-black mb-6 jpn-bracket inline-block">関連商品</h2>
        <div class="grid grid-cols-4 gap-3">
          <% relatedProducts.forEach(relProduct => { %>
            <div class="bg-white border border-gray-200 rounded-lg hover:shadow-lg transition duration-300 overflow-hidden group">
              <a href="/product/<%= relProduct.id %>" class="block">
                <div class="aspect-square bg-gray-50 relative overflow-hidden">
                  <% if (relProduct.image) { %>
                    <img src="<%= relProduct.image %>" alt="<%= relProduct.name %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                  <% } else { %>
                    <div class="w-full h-full flex items-center justify-center text-5xl bg-gradient-to-br from-gray-100 to-gray-200">📦</div>
                  <% } %>
                </div>
                <div class="p-3">
                  <span class="text-xs text-red-600 font-bold bg-red-50 px-2 py-0.5 rounded"><%= relProduct.category %></span>
                  <h3 class="font-medium text-sm mt-2 mb-2 line-clamp-2 h-10 leading-tight"><%= relProduct.name %></h3>
                  <span class="text-lg font-black text-red-600"><%= formatPrice(relProduct.price) %></span>
                </div>
              </a>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
    
    <!-- 戻るボタン -->
    <div class="mt-8">
      <a href="/products" class="inline-flex items-center gap-2 text-gray-600 hover:text-red-600 font-medium transition">
        ← 商品一覧に戻る
      </a>
    </div>
  </div>

  <!-- フッター / Footer -->
  <footer class="bg-gray-900 text-white mt-8">
    <div class="max-w-7xl mx-auto px-2 py-10">
      <!-- Footer Links -->
      <div class="grid grid-cols-5 gap-8 mb-8">
        <div>
          <h4 class="font-bold mb-4 text-sm">【ご利用ガイド】</h4>
          <ul class="space-y-2 text-xs text-gray-400">
            <li><a href="#" class="hover:text-white transition">ご注文方法</a></li>
            <li><a href="#" class="hover:text-white transition">お支払い方法</a></li>
            <li><a href="#" class="hover:text-white transition">配送について</a></li>
            <li><a href="#" class="hover:text-white transition">返品・交換</a></li>
            <li><a href="#" class="hover:text-white transition">プライバシーポリシー</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-sm">【会員サービス】</h4>
          <ul class="space-y-2 text-xs text-gray-400">
            <li><a href="#" class="hover:text-white transition">会員登録</a></li>
            <li><a href="#" class="hover:text-white transition">ログイン</a></li>
            <li><a href="#" class="hover:text-white transition">マイページ</a></li>
            <li><a href="#" class="hover:text-white transition">ポイントについて</a></li>
            <li><a href="#" class="hover:text-white transition">会員ランク</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-sm">【サポート】</h4>
          <ul class="space-y-2 text-xs text-gray-400">
            <li><a href="#" class="hover:text-white transition">よくある質問</a></li>
            <li><a href="#" class="hover:text-white transition">お問い合わせ</a></li>
            <li><a href="#" class="hover:text-white transition">店舗情報</a></li>
            <li><a href="#" class="hover:text-white transition">採用情報</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-sm">【企業情報】</h4>
          <ul class="space-y-2 text-xs text-gray-400">
            <li><a href="#" class="hover:text-white transition">会社概要</a></li>
            <li><a href="#" class="hover:text-white transition">利用規約</a></li>
            <li><a href="#" class="hover:text-white transition">特定商取引法</a></li>
            <li><a href="#" class="hover:text-white transition">プレスリリース</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-sm">【お問い合わせ】</h4>
          <div class="text-xs text-gray-400 space-y-2">
            <p>📞 0120-XXX-XXX</p>
            <p>受付時間：10:00〜18:00</p>
            <p>（土日祝日を除く）</p>
            <p class="mt-3">📧 support@mzakka.com</p>
          </div>
        </div>
      </div>
      
      <!-- 18+ Disclaimer -->
      <div class="border-t border-gray-700 pt-6 mb-6">
        <div class="bg-red-900/30 border border-red-800 rounded-lg p-4 text-center">
          <p class="text-red-400 font-bold text-sm mb-1">🔞 年齢制限について</p>
          <p class="text-xs text-gray-400">
            当サイトは成人向け商品を販売しております。18歳未満の方のご利用は固くお断りしております。
          </p>
        </div>
      </div>
      
      <!-- Payment Methods -->
      <div class="text-center mb-6">
        <p class="text-xs text-gray-500 mb-3">対応決済方法</p>
        <div class="flex justify-center gap-4 text-2xl text-gray-400">
          <span>💳</span>
          <span>🏦</span>
          <span>💰</span>
          <span>📱</span>
          <span>🍎</span>
          <span>🅿️</span>
        </div>
      </div>
      
      <!-- Copyright -->
      <div class="border-t border-gray-700 pt-6 text-center text-xs text-gray-500">
        <p>© 2026 M-ZAKKA. All rights reserved. 当サイトの無断転載を禁じます。</p>
      </div>
    </div>
  </footer>

  <script>
    const currentProduct = <%- JSON.stringify(product) %>;
    
    // Age Verification
    function checkAgeVerification() {
      const verified = localStorage.getItem('ageVerified');
      if (!verified) {
        document.getElementById('ageModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    }
    
    function verifyAge(isAdult) {
      if (isAdult) {
        localStorage.setItem('ageVerified', 'true');
        document.getElementById('ageModal').classList.add('hidden');
        document.body.style.overflow = '';
      } else {
        window.location.href = 'https://www.google.com';
      }
    }
    
    // Quantity control
    function changeQuantity(delta) {
      const input = document.getElementById('quantity');
      const current = parseInt(input.value);
      const max = parseInt(input.max);
      const newVal = Math.max(1, Math.min(max, current + delta));
      input.value = newVal;
    }
    
    // Cart functions
    function updateCartCount() {
      const cart = JSON.parse(localStorage.getItem('cart') || '[]');
      const count = cart.reduce((sum, item) => sum + item.quantity, 0);
      document.getElementById('cart-count').textContent = count;
    }
    
    function addToCart() {
      const quantity = parseInt(document.getElementById('quantity').value);
      
      let cart = JSON.parse(localStorage.getItem('cart') || '[]');
      const existingItem = cart.find(item => item.id === currentProduct.id);
      
      if (existingItem) {
        existingItem.quantity += quantity;
      } else {
        cart.push({
          id: currentProduct.id,
          name: currentProduct.name,
          price: currentProduct.price,
          image: currentProduct.image,
          quantity: quantity
        });
      }
      
      localStorage.setItem('cart', JSON.stringify(cart));
      updateCartCount();
      
      // Show success message
      alert('カートに追加しました！');
    }
    
    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
      checkAgeVerification();
      updateCartCount();
    });
  </script>
</body>
</html>
