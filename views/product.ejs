<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/mzakka-theme.css">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Noto Sans TC', sans-serif;
    }
    .jpn-bracket::before { content: '【'; }
    .jpn-bracket::after { content: '】'; }
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .modal-animate {
      animation: slideDown 0.3s ease-out;
    }
  </style>
</head>
<body class="mz-body text-black min-h-screen">

  <%- include('partials/age-modal') %>

  <%- include('partials/header') %>

  <div id="mz-wrapper" class="mz-wrapper max-w-7xl mx-auto px-2 mt-4 mb-4">
    <div class="mz-3col">
      <%- include('partials/sidebar-left') %>

      <div id="wrap_center" class="min-w-0">

  <div class="px-0 py-2">
  <div class="max-w-7xl mx-auto px-0 py-3">
    <nav class="text-xs text-gray-500">
      <a href="/" class="hover:text-red-600">首頁</a>
      <span class="mx-2">›</span>
      <a href="/products" class="hover:text-red-600">商品列表</a>
      <span class="mx-2">›</span>
      <span class="text-red-600 font-medium"><%= product.name %></span>
    </nav>
  </div>

  <!-- 商品詳情 -->
  <div class="max-w-7xl mx-auto px-0 py-4">
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-6">
        <!-- 商品圖片 -->
        <div class="space-y-3">
          <div class="aspect-square bg-gray-50 border border-gray-200 rounded-lg flex items-center justify-center p-8 relative">
            <% if (product.originalPrice && product.originalPrice > product.price) { %>
              <div class="absolute top-4 left-4 z-10">
                <span class="bg-red-600 text-white text-sm px-4 py-2 rounded-lg font-bold">
                  <%= t('product.badge.deal') %>
                </span>
              </div>
            <% } %>

            <% const gallery = (product && Array.isArray(product.images) && product.images.length) ? product.images : (product.image ? [product.image] : []); %>
            <% if (gallery.length) { %>
              <img id="mz-product-main-image" src="<%= gallery[0] %>" alt="<%= product.name %>" class="w-full h-full object-contain rounded-lg">
            <% } else { %>
              <span class="text-9xl">📦</span>
            <% } %>
          </div>

          <% if (gallery.length > 1) { %>
            <div id="mz-product-thumbs" class="grid grid-cols-5 gap-2">
              <% gallery.slice(0, 10).forEach((img, idx) => { %>
                <button type="button" data-mz-image="<%= img %>" aria-label="切換圖片 <%= idx + 1 %>" class="<%= idx === 0 ? 'ring-2 ring-red-600' : 'ring-1 ring-gray-200' %> bg-white rounded overflow-hidden aspect-square">
                  <img src="<%= img %>" alt="" class="w-full h-full object-cover">
                </button>
              <% }) %>
            </div>
          <% } %>
        </div>
        
        <!-- 商品資料 -->
        <div class="flex flex-col">
          <span class="text-xs text-red-600 font-bold bg-red-50 px-3 py-1 rounded w-fit mb-3"><%= product.category %></span>
          <h1 class="text-2xl font-black text-gray-900 mb-4"><%= product.name %></h1>
          
          <!-- 價格 -->
          <div class="mb-6 bg-gray-50 p-4 rounded-lg">
            <div class="flex items-baseline gap-3">
              <span class="text-4xl font-black text-red-600"><%= formatPrice(product.price) %></span>
              <% if (product.originalPrice && product.originalPrice > product.price) { %>
                <span class="text-lg text-gray-400 line-through"><%= formatPrice(product.originalPrice) %></span>
                <span class="bg-red-100 text-red-600 px-3 py-1 rounded-lg text-sm font-bold">
                  <%= Math.round((1 - product.price / product.originalPrice) * 100) %>%OFF
                </span>
              <% } %>
            </div>
            <div class="mt-3 text-sm text-gray-600">
              <span class="text-red-600 font-bold">可獲積分：<%= Math.floor(product.price / 100) %>pt</span>
              <span class="text-gray-400 ml-2">（1 倍）</span>
            </div>
          </div>
          
          <!-- 存貨 -->
          <div class="mb-4 flex items-center gap-4">
            <span class="text-sm">📦 存貨：</span>
            <% if (product.stock > 20) { %>
              <span class="font-bold text-green-600 bg-green-50 px-3 py-1 rounded text-sm">有貨</span>
            <% } else if (product.stock > 0) { %>
              <span class="font-bold text-orange-600 bg-orange-50 px-3 py-1 rounded text-sm">存貨緊張（剩餘 <%= product.stock %> 件）</span>
            <% } else { %>
              <span class="font-bold text-gray-500 bg-gray-100 px-3 py-1 rounded text-sm">缺貨</span>
            <% } %>
          </div>
          
          <!-- 商品介紹 -->
          <div class="border-t border-b py-4 mb-6">
            <h3 class="font-bold text-gray-900 mb-3 jpn-bracket">商品介紹</h3>
            <p class="text-gray-600 leading-relaxed text-sm whitespace-pre-line">
              <% const _desc = (product && product.description != null) ? String(product.description).trim() : ''; %>
              <% const _name = (product && product.name != null) ? String(product.name).trim() : ''; %>
              <%= (_desc && _desc !== _name) ? _desc : '暫未提供產品詳細介紹。' %>
            </p>
          </div>
          
          <!-- 購買區 -->
          <div class="mt-auto space-y-4">
            <div class="flex items-center gap-4">
              <label class="text-gray-700 font-medium text-sm">數量：</label>
              <div class="flex items-center border border-gray-300 rounded-lg">
                <button onclick="changeQuantity(-1)" class="px-4 py-2 hover:bg-gray-100 transition font-bold">－</button>
                <input type="number" id="quantity" value="1" min="1" max="<%= product.stock %>" class="w-16 text-center border-x border-gray-300 py-2 focus:outline-none font-medium">
                <button onclick="changeQuantity(1)" class="px-4 py-2 hover:bg-gray-100 transition font-bold">＋</button>
              </div>
            </div>
            
            <div class="flex gap-3">
              <button onclick="addToCart()" class="flex-1 bg-red-600 text-white py-4 rounded-lg font-bold text-lg hover:bg-red-700 transition flex items-center justify-center gap-2">
                🛒 加入購物車
              </button>
              <button class="bg-gray-100 text-gray-700 px-6 py-4 rounded-lg font-bold hover:bg-gray-200 transition">
                ❤️
              </button>
            </div>
            
            <div class="flex gap-3 text-xs">
              <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full font-medium">🚚 免運費</span>
              <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full font-medium">📦 即日出貨</span>
              <span class="bg-purple-100 text-purple-700 px-3 py-1 rounded-full font-medium">🔒 安全付款</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- 相關商品 -->
    <% if (relatedProducts && relatedProducts.length > 0) { %>
      <div class="mt-10">
        <h2 class="text-xl font-black mb-6 jpn-bracket inline-block">相關商品</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
          <% relatedProducts.forEach(relProduct => { %>
            <div class="bg-white border border-gray-200 rounded-lg hover:shadow-lg transition duration-300 overflow-hidden group">
              <a href="/product/<%= relProduct.id %>" class="block">
                <div class="aspect-square bg-gray-50 relative overflow-hidden">
                  <% if (relProduct.image) { %>
                    <img src="<%= relProduct.image %>" alt="<%= relProduct.name %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                  <% } else { %>
                    <div class="w-full h-full flex items-center justify-center text-5xl bg-gradient-to-br from-gray-100 to-gray-200">📦</div>
                  <% } %>
                </div>
                <div class="p-3">
                  <span class="text-xs text-red-600 font-bold bg-red-50 px-2 py-0.5 rounded"><%= relProduct.category %></span>
                  <h3 class="font-medium text-sm mt-2 mb-2 line-clamp-2 h-10 leading-tight"><%= relProduct.name %></h3>
                  <span class="text-lg font-black text-red-600"><%= formatPrice(relProduct.price) %></span>
                </div>
              </a>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
    
    <!-- 返回 -->
    <div class="mt-8">
      <a href="/products" class="inline-flex items-center gap-2 text-gray-600 hover:text-red-600 font-medium transition">
        ← 返回商品列表
      </a>
    </div>
  </div>
      </div>
      </div>

      <%- include('partials/sidebar-right') %>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script id="current-product" type="application/json"><%- JSON.stringify(product) %></script>

  <script>
    const currentProduct = JSON.parse(document.getElementById('current-product').textContent || '{}');
    
    // 年齡確認
    function checkAgeVerification() {
      const verified = localStorage.getItem('ageVerified');
      if (!verified) {
        document.getElementById('ageModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    }
    
    function verifyAge(isAdult) {
      if (isAdult) {
        localStorage.setItem('ageVerified', 'true');
        document.getElementById('ageModal').classList.add('hidden');
        document.body.style.overflow = '';
      } else {
        window.location.href = 'https://www.google.com';
      }
    }

    function toggleCategories() {
      const list = document.getElementById('catList');
      const toggle = document.getElementById('catToggle');
      if (!list || !toggle) return;
      const hidden = list.classList.contains('hidden');
      if (hidden) {
        list.classList.remove('hidden');
        toggle.textContent = '▲';
      } else {
        list.classList.add('hidden');
        toggle.textContent = '▼';
      }
    }
    
    // 數量控制
    function changeQuantity(delta) {
      const input = document.getElementById('quantity');
      const current = parseInt(input.value);
      const max = parseInt(input.max);
      const newVal = Math.max(1, Math.min(max, current + delta));
      input.value = newVal;
    }
    
    // 購物車
    function updateCartCount() {
      const cart = JSON.parse(localStorage.getItem('cart') || '[]');
      const count = cart.reduce((sum, item) => sum + item.quantity, 0);
      document.getElementById('cart-count').textContent = count;
    }
    
    function addToCart() {
      const quantity = parseInt(document.getElementById('quantity').value);
      
      let cart = JSON.parse(localStorage.getItem('cart') || '[]');
      const existingItem = cart.find(item => item.id === currentProduct.id);
      
      if (existingItem) {
        existingItem.quantity += quantity;
      } else {
        cart.push({
          id: currentProduct.id,
          name: currentProduct.name,
          price: currentProduct.price,
          image: currentProduct.image,
          quantity: quantity
        });
      }
      
      localStorage.setItem('cart', JSON.stringify(cart));
      updateCartCount();
      
      alert('已加入購物車！');
    }

    function initGalleryThumbs() {
      const main = document.getElementById('mz-product-main-image');
      const thumbs = document.getElementById('mz-product-thumbs');
      if (!main || !thumbs) return;
      thumbs.addEventListener('click', (e) => {
        const btn = e.target && e.target.closest ? e.target.closest('button[data-mz-image]') : null;
        if (!btn) return;
        const src = btn.getAttribute('data-mz-image');
        if (!src) return;
        main.setAttribute('src', src);
        for (const el of thumbs.querySelectorAll('button[data-mz-image]')) {
          el.classList.remove('ring-2', 'ring-red-600');
          el.classList.add('ring-1', 'ring-gray-200');
        }
        btn.classList.remove('ring-1', 'ring-gray-200');
        btn.classList.add('ring-2', 'ring-red-600');
      });
    }
    
    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
      checkAgeVerification();
      updateCartCount();
      initGalleryThumbs();
    });
  </script>
</body>
</html>
