  <header class="mz-header bg-white border-b border-gray-300 sticky top-0 z-50">
    <div class="mz-topbar bg-gray-100 border-b border-gray-300 text-[11px] leading-6">
      <div class="max-w-7xl mx-auto px-2 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/cart" class="hover:underline">購物車</a>
          <a href="/products?page=1" class="hover:underline">注目商品</a>
          <a href="#" class="hover:underline">使用指南</a>
          <a href="#" class="hover:underline">常見問題</a>
          <a href="<%= user ? '#' : '/login' %>" class="hover:underline">我的頁面</a>
          <a href="#" class="hover:underline">聯絡我們</a>
        </div>
        <div class="hidden sm:flex items-center gap-3">
          <% if (user) { %>
            <span class="text-gray-600">已登入</span>
            <a href="/logout" class="hover:underline">登出</a>
          <% } else { %>
            <a href="/login" class="hover:underline"><%= t('nav.login') %></a>
            <a href="/register" class="hover:underline"><%= t('nav.register') %></a>
          <% } %>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-2 py-2">
      <div class="flex items-center gap-3">
        <a href="/" class="flex items-center gap-2 flex-shrink-0">
          <span class="text-2xl font-black text-red-700 tracking-tight">OHYA2.0</span>
        </a>

        <form action="/products" method="get" class="flex-1">
          <div class="flex items-stretch">
            <select name="category" class="hidden sm:block w-44 border border-gray-400 bg-white text-xs px-2">
              <% (categories || []).slice(0, 50).forEach(cat => { %>
                <option value="<%= cat.slug %>" <%= (typeof selectedCategorySlug === 'string' && selectedCategorySlug === cat.slug) ? 'selected' : '' %>><%= cat.name %></option>
              <% }) %>
            </select>
            <input name="q" type="text" placeholder="搜尋商品" class="flex-1 border border-gray-400 px-3 text-sm h-9 focus:outline-none">
            <button type="submit" class="bg-red-700 text-white px-5 text-sm font-bold h-9">搜尋</button>
          </div>
        </form>

        <div class="flex items-center gap-3 flex-shrink-0 text-xs">
          <a href="/cart" class="flex items-center gap-1 hover:underline">
            <span>購物車</span>
            <span class="bg-red-700 text-white text-[10px] px-2 py-0.5 rounded-full font-bold" id="cart-count">0</span>
          </a>
          <span class="hidden sm:inline text-gray-500">|</span>
          <a href="<%= user ? '#' : '/login' %>" class="hidden sm:inline hover:underline">會員</a>
        </div>
      </div>
    </div>

    <nav class="mz-nav bg-gray-50 border-t border-gray-300 border-b border-gray-300">
      <div class="max-w-7xl mx-auto px-2">
        <div class="flex items-center">
          <div class="relative group flex-shrink-0">
            <button type="button" class="bg-red-700 text-white px-3 h-9 text-xs font-bold flex items-center gap-2">
              <span>商品分類</span>
              <span class="text-[10px]">▼</span>
            </button>
            <div class="absolute left-0 top-full bg-white border border-gray-300 w-64 hidden group-hover:block z-50">
              <% (categories || []).forEach(cat => { %>
                <% const href = cat.slug === 'all' ? '/products?page=1' : ('/products?category=' + encodeURIComponent(cat.slug) + '&page=1'); %>
                <a href="<%= href %>" class="block px-3 py-2 text-xs text-gray-900 hover:bg-gray-100 border-b border-gray-100">
                  <%= cat.name %> <span class="text-gray-400">(<%= cat.count %>)</span>
                </a>
              <% }) %>
            </div>
          </div>

          <div class="flex-1 overflow-x-auto">
            <div class="flex min-w-max">
              <% (categories || []).slice(1, 60).forEach(cat => { %>
                <a href="/products?category=<%= encodeURIComponent(cat.slug) %>&page=1" class="h-9 px-3 text-xs text-gray-900 flex items-center border-r border-gray-200 hover:bg-white hover:underline whitespace-nowrap">
                  <%= cat.name %>
                </a>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </nav>
  </header>
