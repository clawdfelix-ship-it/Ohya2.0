<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Noto Sans JP', sans-serif;
    }
    .jpn-bracket::before { content: '【'; }
    .jpn-bracket::after { content: '】'; }
    .product-grid {
      gap: 0.75rem;
    }
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .modal-animate {
      animation: slideDown 0.3s ease-out;
    }
  </style>
</head>
<body class="bg-white text-black min-h-screen">

  <!-- 年齢確認モーダル / Age Verification Modal -->
  <div id="ageModal" class="fixed inset-0 bg-black/80 z-[100] flex items-center justify-center hidden">
    <div class="modal-animate bg-white rounded-lg p-8 max-w-md w-full mx-4 text-center shadow-2xl">
      <div class="text-5xl mb-4">🔞</div>
      <h2 class="text-2xl font-bold mb-4">年齢確認</h2>
      <p class="text-gray-600 mb-6">
        このサイトには成人向けの商品が含まれています。<br>
        18歳以上ですか？
      </p>
      <div class="flex gap-4 justify-center">
        <button onclick="verifyAge(true)" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-10 rounded-lg transition text-lg">
          はい
        </button>
        <button onclick="verifyAge(false)" class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold py-3 px-10 rounded-lg transition text-lg">
          いいえ
        </button>
      </div>
      <p class="text-xs text-gray-400 mt-6">
        ※「いいえ」をクリックすると、このサイトを閲覧できません。
      </p>
    </div>
  </div>

  <!-- ヘッダー / Header -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <!-- Top Bar -->
    <div class="bg-gray-900 text-white text-xs py-1">
      <div class="max-w-7xl mx-auto px-2 flex justify-between items-center">
        <span class="text-orange-400 font-bold">【ポイント5倍】会員登録でさらにお得！</span>
        <div class="flex gap-4">
          <a href="#" class="hover:text-orange-400">マイページ</a>
          <a href="#" class="hover:text-orange-400">よくある質問</a>
          <a href="#" class="hover:text-orange-400">お問い合わせ</a>
        </div>
      </div>
    </div>
    
    <!-- Main Header -->
    <div class="max-w-7xl mx-auto px-2 py-3">
      <div class="flex items-center justify-between gap-4">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 flex-shrink-0">
          <span class="text-3xl">🏪</span>
          <span class="text-xl font-black text-red-600">M-ZAKKA</span>
        </a>
        
        <!-- Search -->
        <div class="flex-1 max-w-xl">
          <div class="flex">
            <input type="text" placeholder="商品名・ブランドで検索" class="flex-1 border-2 border-gray-300 rounded-l-lg px-4 py-2 text-sm focus:border-red-500 focus:outline-none">
            <button class="bg-red-600 text-white px-6 rounded-r-lg hover:bg-red-700 transition font-bold">
              検索
            </button>
          </div>
        </div>
        
        <!-- Cart & Account -->
        <div class="flex items-center gap-4 flex-shrink-0">
          <a href="/cart" class="flex items-center gap-1 text-sm hover:text-red-600 transition">
            <span class="text-xl">🛒</span>
            <span>カート</span>
            <span class="bg-red-600 text-white text-xs px-2 py-0.5 rounded-full font-bold" id="cart-count">0</span>
          </a>
          <% if (user) { %>
            <div class="text-sm">
              <span class="text-gray-600">ようこそ</span>
              <a href="/logout" class="text-red-600 hover:underline ml-2">ログアウト</a>
            </div>
          <% } else { %>
            <a href="/login" class="text-sm hover:text-red-600 transition">ログイン</a>
            <a href="/register" class="bg-red-600 text-white text-sm px-4 py-1.5 rounded hover:bg-red-700 transition font-bold">新規登録</a>
          <% } %>
        </div>
      </div>
    </div>
    
    <!-- Category Navigation - Japanese Style Dense -->
    <nav class="bg-gray-100 border-t border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-2">
        <div class="flex items-center gap-0">
          <!-- Category Dropdown -->
          <div class="relative group">
            <button class="bg-red-600 text-white px-4 py-2.5 font-bold text-sm flex items-center gap-2 hover:bg-red-700 transition">
              <span>☰</span>
              商品カテゴリー
              <span>▼</span>
            </button>
            <div class="absolute left-0 top-full bg-white shadow-xl border border-gray-200 w-64 hidden group-hover:block z-50">
              <% categories.forEach(cat => { %>
                <a href="/products?category=<%= cat.name %>" class="block px-4 py-2.5 text-sm hover:bg-red-50 hover:text-red-600 border-b border-gray-100">
                  <%= cat.name %> <span class="text-gray-400">(<%= cat.count %>)</span>
                </a>
              <% }) %>
            </div>
          </div>
          
          <!-- Quick Category Links -->
          <div class="flex overflow-x-auto no-scrollbar flex-1">
            <a href="/products?category=男士護理" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">メンズケア</a>
            <a href="/products?category=護理配件" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">アクセサリー</a>
            <a href="/products?category=進階系列" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">アドバンス</a>
            <a href="/products?category=頂級系列" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">プレミアム</a>
            <a href="/products?category=優惠套裝" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">お得セット</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">新着商品</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">人気ランキング</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">タイムセール</a>
            <a href="#" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap hover:bg-white hover:text-red-600 transition border-r border-gray-200">ブランド一覧</a>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <!-- パンくずリスト / Breadcrumb -->
  <div class="max-w-7xl mx-auto px-2 py-3">
    <nav class="text-xs text-gray-500">
      <a href="/" class="hover:text-red-600">ホーム</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700 font-medium">商品一覧</span>
      <% if (selectedCategory && selectedCategory !== '全部商品') { %>
        <span class="mx-2">›</span>
        <span class="text-red-600 font-medium"><%= selectedCategory %></span>
      <% } %>
    </nav>
  </div>

  <!-- 商品リスト / Products List -->
  <div class="max-w-7xl mx-auto px-2 py-4">
    <!-- Page Title -->
    <div class="mb-6">
      <h1 class="text-2xl font-black jpn-bracket inline-block">
        <%= selectedCategory && selectedCategory !== '全部商品' ? selectedCategory : '全商品' %>
      </h1>
      <span class="text-sm text-gray-500 ml-3">全 <%= products.length %> 件</span>
    </div>
    
    <!-- Category Filters -->
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-6">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-sm font-bold text-gray-700">カテゴリー：</span>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/products" class="<%= selectedCategory === '全部商品' || !selectedCategory ? 'bg-red-600 text-white' : 'bg-white text-gray-700 border border-gray-300' %> text-xs px-4 py-2 rounded font-medium hover:opacity-80 transition">
          全商品 (<%= products.length %>)
        </a>
        <% categories.slice(1).forEach(category => { %>
          <a href="/products?category=<%= category.name %>" class="<%= selectedCategory === category.name ? 'bg-red-600 text-white' : 'bg-white text-gray-700 border border-gray-300' %> text-xs px-4 py-2 rounded font-medium hover:opacity-80 transition">
            <%= category.name %> (<%= category.count %>)
          </a>
        <% }) %>
      </div>
    </div>
    
    <!-- Sort Options -->
    <div class="flex justify-between items-center mb-4">
      <div class="text-sm text-gray-500">
        <span class="font-bold text-black"><%= products.length %></span> 件の商品が見つかりました
      </div>
      <div class="flex gap-2">
        <select class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:border-red-500 focus:outline-none">
          <option>おすすめ順</option>
          <option>価格の安い順</option>
          <option>価格の高い順</option>
          <option>新着順</option>
          <option>人気順</option>
        </select>
        <div class="flex border border-gray-300 rounded overflow-hidden">
          <button class="px-3 py-1.5 text-sm bg-red-600 text-white">4列</button>
          <button class="px-3 py-1.5 text-sm bg-white text-gray-700 hover:bg-gray-100">リスト</button>
        </div>
      </div>
    </div>
    
    <!-- Products Grid -->
    <% if (products && products.length > 0) { %>
      <div class="grid grid-cols-4 gap-3 product-grid">
        <% products.forEach(product => { %>
          <div class="bg-white border border-gray-200 rounded-lg hover:shadow-lg transition duration-300 overflow-hidden group">
            <a href="/product/<%= product.id %>" class="block">
              <div class="aspect-square bg-gray-50 relative overflow-hidden">
                <!-- Badges -->
                <div class="absolute top-2 left-2 z-10 flex flex-col gap-1">
                  <% if (product.originalPrice && product.originalPrice > product.price) { %>
                    <span class="bg-red-600 text-white text-xs px-2 py-1 rounded font-bold">
                      お買い得
                    </span>
                    <span class="bg-orange-500 text-white text-xs px-2 py-1 rounded font-bold">
                      -<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%OFF
                    </span>
                  <% } %>
                  <% if (product.stock <= 20) { %>
                    <span class="bg-yellow-500 text-black text-xs px-2 py-1 rounded font-bold">
                      残りわずか
                    </span>
                  <% } %>
                </div>
                <% if (product.image) { %>
                  <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center text-6xl bg-gradient-to-br from-gray-100 to-gray-200">📦</div>
                <% } %>
              </div>
              <div class="p-3">
                <span class="text-xs text-red-600 font-bold bg-red-50 px-2 py-0.5 rounded"><%= product.category %></span>
                <h3 class="font-medium text-sm mt-2 mb-2 line-clamp-2 h-10 leading-tight"><%= product.name %></h3>
                
                <!-- Price Display -->
                <div class="mb-3">
                  <span class="text-xl font-black text-red-600"><%= formatPrice(product.price) %></span>
                  <% if (product.originalPrice && product.originalPrice > product.price) { %>
                    <span class="text-xs text-gray-400 line-through ml-1"><%= formatPrice(product.originalPrice) %></span>
                  <% } %>
                </div>
                
                <!-- Points Display -->
                <div class="text-xs text-red-600 mb-3">
                  <span class="font-bold">ポイント：<%= Math.floor(product.price / 100) %>pt</span>
                  <span class="text-gray-400">(1倍)</span>
                </div>
                
                <!-- CTAs -->
                <div class="flex gap-2">
                  <a href="/product/<%= product.id %>" class="flex-1 bg-red-600 hover:bg-red-700 text-white text-center py-2 rounded font-bold text-xs transition">
                    詳細を見る
                  </a>
                  <button onclick="addToCart(<%= product.id %>)" class="bg-orange-500 hover:bg-orange-600 text-white px-3 py-2 rounded font-bold text-xs transition">
                    🛒
                  </button>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
      
      <!-- Pagination -->
      <div class="flex justify-center mt-10">
        <div class="flex gap-1">
          <button class="w-10 h-10 border border-gray-300 rounded font-bold text-gray-400 cursor-not-allowed">«</button>
          <button class="w-10 h-10 bg-red-600 text-white rounded font-bold">1</button>
          <button class="w-10 h-10 border border-gray-300 rounded font-bold hover:bg-gray-100 transition">2</button>
          <button class="w-10 h-10 border border-gray-300 rounded font-bold hover:bg-gray-100 transition">3</button>
          <span class="w-10 h-10 flex items-center justify-center text-gray-400">...</span>
          <button class="w-10 h-10 border border-gray-300 rounded font-bold hover:bg-gray-100 transition">»</button>
        </div>
      </div>
    <% } else { %>
      <div class="text-center py-20 bg-gray-50 rounded-lg border border-gray-200">
        <span class="text-6xl mb-4 block">📦</span>
        <p class="text-gray-500 mb-4">該当する商品が見つかりませんでした</p>
        <a href="/products" class="inline-block bg-red-600 text-white font-bold py-2 px-8 rounded-lg hover:bg-red-700 transition">
          全商品を見る
        </a>
      </div>
    <% } %>
  </div>

  <!-- フッター / Footer -->
  <footer class="bg-gray-900 text-white mt-8">
    <div class="max-w-7xl mx-auto px-2 py-10">
      <!-- Footer Links -->
      <div class="grid grid-cols-5 gap-8 mb-8">
        <div>
          <h4 class="font-bold mb-4 text-sm">【ご利用ガイド】</h4>
          <ul class="space-y-2 text-xs text-gray-400">
            <li><a href="#" class="hover:text-white transition">ご注文方法</a></li>
            <li><a href="#" class="hover:text-white transition">お支払い方法</a></li>
            <li><a href="#" class="hover:text-white transition">配送について</a></li>
            <li><a href="#" class="hover:text-white transition">返品・交換</a></li>
            <li><a href="#" class="hover:text-white transition">プライバシーポリシー</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-sm">【会員サービス】</h4>
          <ul class="space-y-2 text-xs text-gray-400">
            <li><a href="#" class="hover:text-white transition">会員登録</a></li>
            <li><a href="#" class="hover:text-white transition">ログイン</a></li>
            <li><a href="#" class="hover:text-white transition">マイページ</a></li>
            <li><a href="#" class="hover:text-white transition">ポイントについて</a></li>
            <li><a href="#" class="hover:text-white transition">会員ランク</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-sm">【サポート】</h4>
          <ul class="space-y-2 text-xs text-gray-400">
            <li><a href="#" class="hover:text-white transition">よくある質問</a></li>
            <li><a href="#" class="hover:text-white transition">お問い合わせ</a></li>
            <li><a href="#" class="hover:text-white transition">店舗情報</a></li>
            <li><a href="#" class="hover:text-white transition">採用情報</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-sm">【企業情報】</h4>
          <ul class="space-y-2 text-xs text-gray-400">
            <li><a href="#" class="hover:text-white transition">会社概要</a></li>
            <li><a href="#" class="hover:text-white transition">利用規約</a></li>
            <li><a href="#" class="hover:text-white transition">特定商取引法</a></li>
            <li><a href="#" class="hover:text-white transition">プレスリリース</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-sm">【お問い合わせ】</h4>
          <div class="text-xs text-gray-400 space-y-2">
            <p>📞 0120-XXX-XXX</p>
            <p>受付時間：10:00〜18:00</p>
            <p>（土日祝日を除く）</p>
            <p class="mt-3">📧 support@mzakka.com</p>
          </div>
        </div>
      </div>
      
      <!-- 18+ Disclaimer -->
      <div class="border-t border-gray-700 pt-6 mb-6">
        <div class="bg-red-900/30 border border-red-800 rounded-lg p-4 text-center">
          <p class="text-red-400 font-bold text-sm mb-1">🔞 年齢制限について</p>
          <p class="text-xs text-gray-400">
            当サイトは成人向け商品を販売しております。18歳未満の方のご利用は固くお断りしております。
          </p>
        </div>
      </div>
      
      <!-- Payment Methods -->
      <div class="text-center mb-6">
        <p class="text-xs text-gray-500 mb-3">対応決済方法</p>
        <div class="flex justify-center gap-4 text-2xl text-gray-400">
          <span>💳</span>
          <span>🏦</span>
          <span>💰</span>
          <span>📱</span>
          <span>🍎</span>
          <span>🅿️</span>
        </div>
      </div>
      
      <!-- Copyright -->
      <div class="border-t border-gray-700 pt-6 text-center text-xs text-gray-500">
        <p>© 2026 M-ZAKKA. All rights reserved. 当サイトの無断転載を禁じます。</p>
      </div>
    </div>
  </footer>

  <script>
    const productsData = <%- JSON.stringify(products) %>;
    
    // Age Verification
    function checkAgeVerification() {
      const verified = localStorage.getItem('ageVerified');
      if (!verified) {
        document.getElementById('ageModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    }
    
    function verifyAge(isAdult) {
      if (isAdult) {
        localStorage.setItem('ageVerified', 'true');
        document.getElementById('ageModal').classList.add('hidden');
        document.body.style.overflow = '';
      } else {
        window.location.href = 'https://www.google.com';
      }
    }
    
    // Cart functions
    function updateCartCount() {
      const cart = JSON.parse(localStorage.getItem('cart') || '[]');
      const count = cart.reduce((sum, item) => sum + item.quantity, 0);
      document.getElementById('cart-count').textContent = count;
    }
    
    function addToCart(productId) {
      const product = productsData.find(p => p.id === productId);
      if (!product) return;
      
      let cart = JSON.parse(localStorage.getItem('cart') || '[]');
      const existingItem = cart.find(item => item.id === productId);
      
      if (existingItem) {
        existingItem.quantity += 1;
      } else {
        cart.push({
          id: product.id,
          name: product.name,
          price: product.price,
          image: product.image,
          quantity: 1
        });
      }
      
      localStorage.setItem('cart', JSON.stringify(cart));
      updateCartCount();
      
      // Simple feedback
      const btn = event.target;
      const originalText = btn.textContent;
      btn.textContent = '✓';
      btn.classList.add('bg-green-600');
      setTimeout(() => {
        btn.textContent = originalText;
        btn.classList.remove('bg-green-600');
      }, 1000);
    }
    
    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
      checkAgeVerification();
      updateCartCount();
    });
  </script>
</body>
</html>
