<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/mzakka-theme.css">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Noto Sans TC', sans-serif; }
    .jpn-bracket { position: relative; padding: 0 1em; }
    .jpn-bracket::before, .jpn-bracket::after {
      content: ''; position: absolute; top: 50%; width: 0.4em; height: 1em;
      border: 2px solid #dc2626; transform: translateY(-50%);
    }
    .jpn-bracket::before { left: 0; border-right: none; }
    .jpn-bracket::after { right: 0; border-left: none; }
    .modal-animate { animation: modalPop 0.3s ease-out; }
    @keyframes modalPop {
      from { opacity: 0; transform: scale(0.9); }
      to { opacity: 1; transform: scale(1); }
    }
  </style>
</head>
<body class="mz-body text-black min-h-screen">

  <%- include('partials/age-modal') %>

  <%- include('partials/header') %>

  <div id="mz-wrapper" class="mz-wrapper max-w-7xl mx-auto px-2 mt-4 mb-4">
    <div class="mz-3col">
      <%- include('partials/sidebar-left') %>

      <div id="wrap_center" class="min-w-0">
  <main class="max-w-7xl mx-auto px-0 py-2">
    <div class="mb-6">
      <h1 class="text-xl font-black jpn-bracket inline-block"><%= selectedCategory && selectedCategory !== '全部商品' ? selectedCategory : '全部商品' %></h1>
      <span class="text-sm text-gray-500 ml-2">共 <%= (typeof total === 'number' ? total : products.length) %> 件</span>
    </div>

    <!-- 手機版分類篩選 -->
    <div class="md:hidden bg-gray-50 border border-gray-200 rounded-lg p-3 mb-4">
      <div class="flex items-center gap-2 mb-2"><span class="text-sm font-bold text-gray-700">分類：</span></div>
      <div class="flex flex-wrap gap-2">
        <a href="/products" class="<%= selectedCategorySlug === 'all' || !selectedCategorySlug ? 'bg-red-600 text-white' : 'bg-white text-gray-700 border border-gray-300' %> text-xs px-3 py-1.5 rounded font-medium hover:opacity-80 transition">全部 (<%= (typeof total === 'number' ? total : products.length) %>)</a>
        <% categories.slice(1).forEach(category => { %>
          <a href="/products?category=<%= encodeURIComponent(category.slug) %>&page=1" class="<%= selectedCategorySlug === category.slug ? 'bg-red-600 text-white' : 'bg-white text-gray-700 border border-gray-300' %> text-xs px-3 py-1.5 rounded font-medium hover:opacity-80 transition"><%= category.name %></a>
        <% }) %>
      </div>
    </div>

    <!-- 排序 -->
    <div class="flex justify-between items-center mb-6 bg-white border border-gray-200 rounded-lg p-3">
      <div class="text-sm text-gray-500">已找到 <span class="font-bold text-black"><%= (typeof total === 'number' ? total : products.length) %></span> 件商品</div>
      <div class="flex gap-2">
        <select id="mz-sort" class="border border-gray-300 rounded px-2 py-1 text-sm focus:border-red-500 focus:outline-none">
          <option value="recommend" <%= (typeof sort === 'string' ? sort : 'recommend') === 'recommend' ? 'selected' : '' %>>推介排序</option>
          <option value="price_asc" <%= (typeof sort === 'string' ? sort : 'recommend') === 'price_asc' ? 'selected' : '' %>>價格由低至高</option>
          <option value="price_desc" <%= (typeof sort === 'string' ? sort : 'recommend') === 'price_desc' ? 'selected' : '' %>>價格由高至低</option>
          <option value="newest" <%= (typeof sort === 'string' ? sort : 'recommend') === 'newest' ? 'selected' : '' %>>最新上架</option>
          <option value="popular" <%= (typeof sort === 'string' ? sort : 'recommend') === 'popular' ? 'selected' : '' %>>人氣排序</option>
        </select>
      </div>
    </div>

    <!-- 產品列表 -->
    <% if (products && products.length > 0) { %>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <% products.forEach(product => { %>
          <div class="bg-white border border-gray-200 rounded-lg hover:shadow-lg transition duration-300 overflow-hidden group">
            <a href="/product/<%= product.id %>" class="block">
              <div class="aspect-square bg-gray-50 relative overflow-hidden">
                <div class="absolute top-2 left-2 z-10 flex flex-col gap-1">
                  <% if (product.originalPrice && product.originalPrice > product.price) { %>
                    <span class="bg-red-600 text-white text-xs px-2 py-1 rounded font-bold"><%= t('product.badge.deal') %></span>
                    <span class="bg-orange-500 text-white text-xs px-2 py-1 rounded font-bold">-<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%OFF</span>
                  <% } %>
                  <% if (product.stock <= 20) { %>
                    <span class="bg-yellow-500 text-black text-xs px-2 py-1 rounded font-bold"><%= t('product.badge.lowStock') %></span>
                  <% } %>
                </div>
                <% if (product.image) { %>
                  <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center text-6xl bg-gradient-to-br from-gray-100 to-gray-200">📦</div>
                <% } %>
              </div>
              <div class="p-3">
                <span class="text-xs text-red-600 font-bold bg-red-50 px-2 py-0.5 rounded"><%= product.category %></span>
                <h3 class="font-medium text-sm mt-2 mb-2 line-clamp-2 h-10 leading-tight"><%= product.name %></h3>
                <div class="mb-3">
                  <span class="text-xl font-black text-red-600"><%= formatPrice(product.price) %></span>
                  <% if (product.originalPrice && product.originalPrice > product.price) { %>
                    <span class="text-xs text-gray-400 line-through ml-1"><%= formatPrice(product.originalPrice) %></span>
                  <% } %>
                </div>
                <div class="text-xs text-red-600 mb-3">
                  <span class="font-bold">積分：<%= Math.floor(product.price / 100) %>pt</span><span class="text-gray-400">（1 倍）</span>
                </div>
                <div class="flex gap-2">
                  <a href="/product/<%= product.id %>" class="flex-1 bg-red-600 hover:bg-red-700 text-white text-center py-2 rounded font-bold text-xs transition"><%= t('product.cta.details') %></a>
                  <button onclick="addToCart(this)" data-product-id="<%= product.id %>" class="bg-orange-500 hover:bg-orange-600 text-white px-3 py-2 rounded font-bold text-xs transition">🛒</button>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
      <div class="flex justify-center mt-8">
        <% 
          const currentPage = typeof page === 'number' ? page : 1;
          const pages = typeof totalPages === 'number' ? totalPages : 1;
          const qParam = (typeof q === 'string' && q.trim()) ? ('&q=' + encodeURIComponent(q.trim())) : '';
          const sortParam = (typeof sort === 'string' && sort) ? ('&sort=' + encodeURIComponent(sort)) : '';
          const base = selectedCategorySlug && selectedCategorySlug !== 'all'
            ? ('/products?category=' + encodeURIComponent(selectedCategorySlug) + qParam + sortParam + '&page=')
            : ('/products?' + (qParam ? qParam.slice(1) + '&' : '') + (sortParam ? sortParam.slice(1) + '&' : '') + 'page=');
          const startPage = Math.max(1, currentPage - 2);
          const endPage = Math.min(pages, currentPage + 2);
        %>
        <div class="flex gap-1">
          <% if (currentPage <= 1) { %>
            <button class="w-9 h-9 border border-gray-300 rounded font-bold text-gray-400 cursor-not-allowed">«</button>
          <% } else { %>
            <a href="<%= base + (currentPage - 1) %>" class="w-9 h-9 border border-gray-300 rounded font-bold hover:bg-gray-100 transition flex items-center justify-center">«</a>
          <% } %>

          <% if (startPage > 1) { %>
            <a href="<%= base + 1 %>" class="w-9 h-9 border border-gray-300 rounded font-bold hover:bg-gray-100 transition flex items-center justify-center">1</a>
            <% if (startPage > 2) { %>
              <span class="w-9 h-9 flex items-center justify-center text-gray-400">...</span>
            <% } %>
          <% } %>

          <% for (let i = startPage; i <= endPage; i++) { %>
            <% if (i === currentPage) { %>
              <span class="w-9 h-9 bg-red-600 text-white rounded font-bold flex items-center justify-center"><%= i %></span>
            <% } else { %>
              <a href="<%= base + i %>" class="w-9 h-9 border border-gray-300 rounded font-bold hover:bg-gray-100 transition flex items-center justify-center"><%= i %></a>
            <% } %>
          <% } %>

          <% if (endPage < pages) { %>
            <% if (endPage < pages - 1) { %>
              <span class="w-9 h-9 flex items-center justify-center text-gray-400">...</span>
            <% } %>
            <a href="<%= base + pages %>" class="w-9 h-9 border border-gray-300 rounded font-bold hover:bg-gray-100 transition flex items-center justify-center"><%= pages %></a>
          <% } %>

          <% if (currentPage >= pages) { %>
            <button class="w-9 h-9 border border-gray-300 rounded font-bold text-gray-400 cursor-not-allowed">»</button>
          <% } else { %>
            <a href="<%= base + (currentPage + 1) %>" class="w-9 h-9 border border-gray-300 rounded font-bold hover:bg-gray-100 transition flex items-center justify-center">»</a>
          <% } %>
        </div>
      </div>
    <% } else { %>
      <div class="text-center py-20 bg-white rounded-lg border border-gray-200">
        <span class="text-6xl mb-4 block">📦</span>
        <p class="text-gray-500 mb-4">未找到相關商品</p>
        <a href="/products" class="inline-block bg-red-600 text-white font-bold py-2 px-8 rounded-lg hover:bg-red-700 transition">查看全部商品</a>
      </div>
    <% } %>
  </main>
      </div>

      <%- include('partials/sidebar-right') %>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    function verifyAge(isAdult) {
      if (isAdult) {
        document.getElementById('ageModal').classList.add('hidden');
        localStorage.setItem('ageVerified', 'true');
      } else {
        window.location.href = 'https://www.google.com.hk/';
      }
    }
    if (!localStorage.getItem('ageVerified')) {
      document.getElementById('ageModal').classList.remove('hidden');
    }
    function addToCart(btn) {
      const productId = btn.dataset.productId;
      const countEl = document.getElementById('cart-count');
      const current = parseInt(countEl.textContent);
      countEl.textContent = current + 1;
      alert('已加入購物車！');
    }

    function toggleCategories() {
      const list = document.getElementById('catList');
      const toggle = document.getElementById('catToggle');
      if (!list || !toggle) return;
      const hidden = list.classList.contains('hidden');
      if (hidden) {
        list.classList.remove('hidden');
        toggle.textContent = '▲';
      } else {
        list.classList.add('hidden');
        toggle.textContent = '▼';
      }
    }

    (function initSort() {
      const sel = document.getElementById('mz-sort');
      if (!sel) return;
      sel.addEventListener('change', function () {
        const params = new URLSearchParams(window.location.search);
        params.set('sort', String(sel.value || 'recommend'));
        params.set('page', '1');
        const next = window.location.pathname + '?' + params.toString();
        window.location.href = next;
      });
    })();
  </script>
</body>
</html>
