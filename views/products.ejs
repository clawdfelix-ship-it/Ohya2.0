<%- include('partials/head') %>

<body class="bg-gray-50 text-black min-h-screen">

  <!-- 年齡確認 -->
  <div id="ageModal" class="fixed inset-0 bg-black/80 z-[100] flex items-center justify-center hidden">
    <div class="modal-animate bg-white rounded-lg p-8 max-w-md w-full mx-4 text-center shadow-2xl">
      <div class="text-5xl mb-4">🔞</div>
      <h2 class="text-2xl font-bold mb-4"><%= t('age.title') %></h2>
      <p class="text-gray-600 mb-6 whitespace-pre-line"><%= t('age.desc') %></p>
      <div class="flex gap-4 justify-center">
        <button onclick="verifyAge(true)" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-10 rounded-lg transition text-lg">
          <%= t('common.yes') %>
        </button>
        <button onclick="verifyAge(false)" class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold py-3 px-10 rounded-lg transition text-lg">
          <%= t('common.no') %>
        </button>
      </div>
      <p class="text-xs text-gray-400 mt-6">
        選擇「否」將無法繼續瀏覽本網站。
      </p>
    </div>
  </div>

  <%- include('partials/header') %>

  <!-- 三欄布局 Main Content Wrapper -->
  <div id="wrapper" class="max-w-7xl mx-auto px-2 mt-4">
    <div class="flex gap-4">
      
      <!-- 左側邊欄 Left Sidebar (Desktop Only) -->
      <aside class="hidden lg:block w-44 flex-shrink-0">
        <div class="sticky top-24">
          <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
            <div class="bg-red-600 text-white px-3 py-2.5 font-bold text-sm">
              ☰ 商品分類
            </div>
            <nav class="p-1">
              <% categories.forEach(cat => { %>
                <a href="/products?category=<%= cat.name %>" class="block px-3 py-2 text-sm hover:bg-red-50 hover:text-red-600 border-b border-gray-100 last:border-b-0">
                  <%= cat.name %> <span class="text-gray-400">(<%= cat.count %>)</span>
                </a>
              <% }) %>
            </nav>
          </div>
        </div>
      </aside>

      <!-- 中間內容區 Main Content -->
      <main class="flex-1 min-w-0">
        <!-- Page Title -->
        <div class="mb-4">
          <h1 class="text-xl font-black jpn-bracket inline-block"><%= selectedCategory && selectedCategory !== '全部商品' ? selectedCategory : '全部商品' %></h1>
          <span class="text-sm text-gray-500 ml-2">共 <%= products.length %> 件</span>
        </div>

        <!-- Category Filters (Mobile Only) -->
        <div class="lg:hidden bg-gray-50 border border-gray-200 rounded-lg p-3 mb-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-sm font-bold text-gray-700">分類：</span>
          </div>
          <div class="flex flex-wrap gap-2">
            <a href="/products" class="<%= selectedCategory === '全部商品' || !selectedCategory ? 'bg-red-600 text-white' : 'bg-white text-gray-700 border border-gray-300' %> text-xs px-3 py-1.5 rounded font-medium hover:opacity-80 transition">
              全部 (<%= products.length %>)
            </a>
            <% categories.slice(1).forEach(category => { %>
              <a href="/products?category=<%= category.name %>" class="<%= selectedCategory === category.name ? 'bg-red-600 text-white' : 'bg-white text-gray-700 border border-gray-300' %> text-xs px-3 py-1.5 rounded font-medium hover:opacity-80 transition">
                <%= category.name %>
              </a>
            <% }) %>
          </div>
        </div>

        <!-- Sort Options -->
        <div class="flex justify-between items-center mb-4 bg-white border border-gray-200 rounded-lg p-3">
          <div class="text-sm text-gray-500">
            已找到 <span class="font-bold text-black"><%= products.length %></span> 件商品
          </div>
          <div class="flex gap-2">
            <select class="border border-gray-300 rounded px-2 py-1 text-sm focus:border-red-500 focus:outline-none">
              <option>推介排序</option>
              <option>價格由低至高</option>
              <option>價格由高至低</option>
              <option>最新上架</option>
              <option>人氣排序</option>
            </select>
          </div>
        </div>

        <!-- Products Grid -->
        <% if (products && products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-3 product-grid">
            <% products.forEach(product => { %>
              <div class="bg-white border border-gray-200 rounded-lg hover:shadow-lg transition duration-300 overflow-hidden group">
                <a href="/product/<%= product.id %>" class="block">
                  <div class="aspect-square bg-gray-50 relative overflow-hidden">
                    <!-- Badges -->
                    <div class="absolute top-2 left-2 z-10 flex flex-col gap-1">
                      <% if (product.originalPrice && product.originalPrice > product.price) { %>
                        <span class="bg-red-600 text-white text-xs px-2 py-1 rounded font-bold">
                          <%= t('product.badge.deal') %>
                        </span>
                        <span class="bg-orange-500 text-white text-xs px-2 py-1 rounded font-bold">
                          -<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%OFF
                        </span>
                      <% } %>
                      <% if (product.stock <= 20) { %>
                        <span class="bg-yellow-500 text-black text-xs px-2 py-1 rounded font-bold">
                          <%= t('product.badge.lowStock') %>
                        </span>
                      <% } %>
                    </div>
                    <% if (product.image) { %>
                      <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                    <% } else { %>
                      <div class="w-full h-full flex items-center justify-center text-6xl bg-gradient-to-br from-gray-100 to-gray-200">📦</div>
                    <% } %>
                  </div>
                  <div class="p-3">
                    <span class="text-xs text-red-600 font-bold bg-red-50 px-2 py-0.5 rounded"><%= product.category %></span>
                    <h3 class="font-medium text-sm mt-2 mb-2 line-clamp-2 h-10 leading-tight"><%= product.name %></h3>
                    
                    <!-- Price Display -->
                    <div class="mb-3">
                      <span class="text-xl font-black text-red-600"><%= formatPrice(product.price) %></span>
                      <% if (product.originalPrice && product.originalPrice > product.price) { %>
                        <span class="text-xs text-gray-400 line-through ml-1"><%= formatPrice(product.originalPrice) %></span>
                      <% } %>
                    </div>
                    
                    <!-- Points Display -->
                    <div class="text-xs text-red-600 mb-3">
                      <span class="font-bold">積分：<%= Math.floor(product.price / 100) %>pt</span>
                      <span class="text-gray-400">（1 倍）</span>
                    </div>
                    
                    <!-- CTAs -->
                    <div class="flex gap-2">
                      <a href="/product/<%= product.id %>" class="flex-1 bg-red-600 hover:bg-red-700 text-white text-center py-2 rounded font-bold text-xs transition">
                        <%= t('product.cta.details') %>
                      </a>
                      <button onclick="addToCart(this)" data-product-id="<%= product.id %>" class="bg-orange-500 hover:bg-orange-600 text-white px-3 py-2 rounded font-bold text-xs transition">
                        🛒
                      </button>
                    </div>
                  </div>
                </a>
              </div>
            <% }) %>
          </div>
          
          <!-- Pagination -->
          <div class="flex justify-center mt-8">
            <div class="flex gap-1">
              <button class="w-9 h-9 border border-gray-300 rounded font-bold text-gray-400 cursor-not-allowed">«</button>
              <button class="w-9 h-9 bg-red-600 text-white rounded font-bold">1</button>
              <button class="w-9 h-9 border border-gray-300 rounded font-bold hover:bg-gray-100 transition">2</button>
              <button class="w-9 h-9 border border-gray-300 rounded font-bold hover:bg-gray-100 transition">3</button>
              <span class="w-9 h-9 flex items-center justify-center text-gray-400">...</span>
              <button class="w-9 h-9 border border-gray-300 rounded font-bold hover:bg-gray-100 transition">»</button>
            </div>
          </div>
        <% } else { %>
          <div class="text-center py-20 bg-white rounded-lg border border-gray-200">
            <span class="text-6xl mb-4 block">📦</span>
            <p class="text-gray-500 mb-4">未找到相關商品</p>
            <a href="/products" class="inline-block bg-red-600 text-white font-bold py-2 px-8 rounded-lg hover:bg-red-700 transition">
              查看全部商品
            </a>
          </div>
        <% } %>
      </main>

      <!-- 右側邊欄 Right Sidebar (Desktop Only) -->
      <aside class="hidden lg:block w-56 flex-shrink-0">
        <div class="sticky top-24 space-y-4">
          <!-- 最近瀏覽 -->
          <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
            <div class="bg-gray-800 text-white px-3 py-2 font-bold text-sm">
              👁 最近瀏覽
            </div>
            <div class="p-3 text-center text-xs text-gray-400">
              最近冇瀏覽紀錄
            </div>
          </div>

          <!-- 人氣商品 -->
          <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
            <div class="bg-red-600 text-white px-3 py-2 font-bold text-sm">
              🔥 人氣排行榜
            </div>
            <div class="p-2">
              <% products.slice(0, 5).forEach((product, idx) => { %>
                <a href="/product/<%= product.id %>" class="flex gap-2 p-2 hover:bg-gray-50 border-b border-gray-100 last:border-b-0">
                  <span class="w-5 h-5 bg-gray-800 text-white text-xs flex items-center justify-center rounded flex-shrink-0 font-bold"><%= idx + 1 %></span>
                  <div class="flex-1 min-w-0">
                    <span class="text-xs block truncate"><%= product.name %></span>
                    <span class="text-xs text-red-600 font-bold"><%= formatPrice(product.price) %></span>
                  </div>
                </a>
              <% }) %>
            </div>
          </div>

          <!-- Banner Ad -->
          <div class="bg-gradient-to-br from-red-600 to-red-700 rounded-lg p-4 text-white text-center">
            <div class="text-3xl mb-2">🎁</div>
            <div class="font-bold text-sm">新會員優惠</div>
            <div class="text-xs text-red-100 mt-1">首次購物即減 $50</div>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    // 年齡確認
    function verifyAge(isAdult) {
      if (isAdult) {
        document.getElementById('ageModal').classList.add('hidden');
        localStorage.setItem('ageVerified', 'true');
      } else {
        window.location.href = 'https://www.google.com.hk/';
      }
    }
    
    // 檢查年齡確認狀態
    if (!localStorage.getItem('ageVerified')) {
      document.getElementById('ageModal').classList.remove('hidden');
    }

    // 加入購物車
    function addToCart(btn) {
      const productId = btn.dataset.productId;
      const countEl = document.getElementById('cart-count');
      const current = parseInt(countEl.textContent);
      countEl.textContent = current + 1;
      alert('已加入購物車！');
    }
  </script>
</body>
</html>
