<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Noto Sans TC', sans-serif; }
    .jpn-bracket { position: relative; padding: 0 1em; }
    .jpn-bracket::before, .jpn-bracket::after {
      content: ''; position: absolute; top: 50%; width: 0.4em; height: 1em;
      border: 2px solid #dc2626; transform: translateY(-50%);
    }
    .jpn-bracket::before { left: 0; border-right: none; }
    .jpn-bracket::after { right: 0; border-left: none; }
    .modal-animate { animation: modalPop 0.3s ease-out; }
    @keyframes modalPop {
      from { opacity: 0; transform: scale(0.9); }
      to { opacity: 1; transform: scale(1); }
    }
  </style>
</head>
<body class="bg-gray-50 text-black min-h-screen">

  <!-- 年齡確認 -->
  <div id="ageModal" class="fixed inset-0 bg-black/80 z-[100] flex items-center justify-center hidden">
    <div class="modal-animate bg-white rounded-lg p-8 max-w-md w-full mx-4 text-center shadow-2xl">
      <div class="text-5xl mb-4">🔞</div>
      <h2 class="text-2xl font-bold mb-4"><%= t('age.title') %></h2>
      <p class="text-gray-600 mb-6 whitespace-pre-line"><%= t('age.desc') %></p>
      <div class="flex gap-4 justify-center">
        <button onclick="verifyAge(true)" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-10 rounded-lg transition text-lg"><%= t('common.yes') %></button>
        <button onclick="verifyAge(false)" class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold py-3 px-10 rounded-lg transition text-lg"><%= t('common.no') %></button>
      </div>
      <p class="text-xs text-gray-400 mt-6">選擇「否」將無法繼續瀏覽本網站。</p>
    </div>
  </div>

  <!-- Header -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <div class="bg-gray-900 text-white text-xs py-1">
      <div class="max-w-7xl mx-auto px-2 flex justify-between items-center">
        <span class="text-orange-400 font-bold">【積分 5 倍】註冊會員更抵！</span>
        <div class="hidden sm:flex gap-4">
          <a href="#" class="hover:text-orange-400"><%= t('nav.myAccount') %></a>
          <a href="#" class="hover:text-orange-400"><%= t('nav.faq') %></a>
          <a href="#" class="hover:text-orange-400"><%= t('nav.contact') %></a>
        </div>
      </div>
    </div>
    <div class="max-w-7xl mx-auto px-2">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 flex-shrink-0">
          <span class="text-3xl">🏪</span>
          <span class="text-xl font-black text-red-600">OHYA2.0</span>
        </a>
        <!-- 桌面版搜尋 -->
        <div class="hidden md:flex flex-1 max-w-xl mx-8">
          <div class="flex w-full">
            <input type="text" placeholder="<%= t('nav.searchPlaceholder') %>" class="flex-1 border-2 border-gray-300 rounded-l-lg px-4 py-2 text-sm focus:border-red-500 focus:outline-none">
            <button class="bg-red-600 text-white px-6 rounded-r-lg hover:bg-red-700 transition"><%= t('nav.search') %></button>
          </div>
        </div>
        <!-- 手機版搜尋按鈕 (隱藏輸入框，唔會出界) -->
        <button class="md:hidden p-2 text-gray-600 hover:text-red-600">🔍</button>
        <div class="flex items-center gap-2 flex-shrink-0">
          <a href="/cart" class="relative p-2 text-gray-600 hover:text-red-600 transition">
            <span class="text-xl">🛒</span>
            <span id="cart-count" class="absolute -top-0 -right-0 bg-red-600 text-white text-xs w-5 h-5 flex items-center justify-center rounded-full font-bold">0</span>
          </a>
          <a href="/login" class="hidden sm:inline-flex bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg font-bold text-sm transition"><%= t('nav.login') %></a>
        </div>
      </div>
    </div>
    <div class="bg-red-600">
      <div class="max-w-7xl mx-auto px-2">
        <div class="flex items-center justify-center h-10 overflow-x-auto">
          <% categories.slice(0, 8).forEach(category => { %>
            <a href="/products?category=<%= category.name %>" class="text-white hover:bg-red-700 px-3 py-2 text-xs font-medium whitespace-nowrap transition"><%= category.name %></a>
          <% }) %>
        </div>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-2 py-6">
    <div class="mb-6">
      <h1 class="text-xl font-black jpn-bracket inline-block"><%= selectedCategory && selectedCategory !== '全部商品' ? selectedCategory : '全部商品' %></h1>
      <span class="text-sm text-gray-500 ml-2">共 <%= products.length %> 件</span>
    </div>

    <!-- 手機版分類篩選 -->
    <div class="md:hidden bg-gray-50 border border-gray-200 rounded-lg p-3 mb-4">
      <div class="flex items-center gap-2 mb-2"><span class="text-sm font-bold text-gray-700">分類：</span></div>
      <div class="flex flex-wrap gap-2">
        <a href="/products" class="<%= selectedCategory === '全部商品' || !selectedCategory ? 'bg-red-600 text-white' : 'bg-white text-gray-700 border border-gray-300' %> text-xs px-3 py-1.5 rounded font-medium hover:opacity-80 transition">全部 (<%= products.length %>)</a>
        <% categories.slice(1).forEach(category => { %>
          <a href="/products?category=<%= category.name %>" class="<%= selectedCategory === category.name ? 'bg-red-600 text-white' : 'bg-white text-gray-700 border border-gray-300' %> text-xs px-3 py-1.5 rounded font-medium hover:opacity-80 transition"><%= category.name %></a>
        <% }) %>
      </div>
    </div>

    <!-- 排序 -->
    <div class="flex justify-between items-center mb-6 bg-white border border-gray-200 rounded-lg p-3">
      <div class="text-sm text-gray-500">已找到 <span class="font-bold text-black"><%= products.length %></span> 件商品</div>
      <div class="flex gap-2">
        <select class="border border-gray-300 rounded px-2 py-1 text-sm focus:border-red-500 focus:outline-none">
          <option>推介排序</option><option>價格由低至高</option><option>價格由高至低</option><option>最新上架</option><option>人氣排序</option>
        </select>
      </div>
    </div>

    <!-- 產品列表 -->
    <% if (products && products.length > 0) { %>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <% products.forEach(product => { %>
          <div class="bg-white border border-gray-200 rounded-lg hover:shadow-lg transition duration-300 overflow-hidden group">
            <a href="/product/<%= product.id %>" class="block">
              <div class="aspect-square bg-gray-50 relative overflow-hidden">
                <div class="absolute top-2 left-2 z-10 flex flex-col gap-1">
                  <% if (product.originalPrice && product.originalPrice > product.price) { %>
                    <span class="bg-red-600 text-white text-xs px-2 py-1 rounded font-bold"><%= t('product.badge.deal') %></span>
                    <span class="bg-orange-500 text-white text-xs px-2 py-1 rounded font-bold">-<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%OFF</span>
                  <% } %>
                  <% if (product.stock <= 20) { %>
                    <span class="bg-yellow-500 text-black text-xs px-2 py-1 rounded font-bold"><%= t('product.badge.lowStock') %></span>
                  <% } %>
                </div>
                <% if (product.image) { %>
                  <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center text-6xl bg-gradient-to-br from-gray-100 to-gray-200">📦</div>
                <% } %>
              </div>
              <div class="p-3">
                <span class="text-xs text-red-600 font-bold bg-red-50 px-2 py-0.5 rounded"><%= product.category %></span>
                <h3 class="font-medium text-sm mt-2 mb-2 line-clamp-2 h-10 leading-tight"><%= product.name %></h3>
                <div class="mb-3">
                  <span class="text-xl font-black text-red-600"><%= formatPrice(product.price) %></span>
                  <% if (product.originalPrice && product.originalPrice > product.price) { %>
                    <span class="text-xs text-gray-400 line-through ml-1"><%= formatPrice(product.originalPrice) %></span>
                  <% } %>
                </div>
                <div class="text-xs text-red-600 mb-3">
                  <span class="font-bold">積分：<%= Math.floor(product.price / 100) %>pt</span><span class="text-gray-400">（1 倍）</span>
                </div>
                <div class="flex gap-2">
                  <a href="/product/<%= product.id %>" class="flex-1 bg-red-600 hover:bg-red-700 text-white text-center py-2 rounded font-bold text-xs transition"><%= t('product.cta.details') %></a>
                  <button onclick="addToCart(this)" data-product-id="<%= product.id %>" class="bg-orange-500 hover:bg-orange-600 text-white px-3 py-2 rounded font-bold text-xs transition">🛒</button>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
      <div class="flex justify-center mt-8">
        <div class="flex gap-1">
          <button class="w-9 h-9 border border-gray-300 rounded font-bold text-gray-400 cursor-not-allowed">«</button>
          <button class="w-9 h-9 bg-red-600 text-white rounded font-bold">1</button>
          <button class="w-9 h-9 border border-gray-300 rounded font-bold hover:bg-gray-100 transition">2</button>
          <button class="w-9 h-9 border border-gray-300 rounded font-bold hover:bg-gray-100 transition">3</button>
          <span class="w-9 h-9 flex items-center justify-center text-gray-400">...</span>
          <button class="w-9 h-9 border border-gray-300 rounded font-bold hover:bg-gray-100 transition">»</button>
        </div>
      </div>
    <% } else { %>
      <div class="text-center py-20 bg-white rounded-lg border border-gray-200">
        <span class="text-6xl mb-4 block">📦</span>
        <p class="text-gray-500 mb-4">未找到相關商品</p>
        <a href="/products" class="inline-block bg-red-600 text-white font-bold py-2 px-8 rounded-lg hover:bg-red-700 transition">查看全部商品</a>
      </div>
    <% } %>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white mt-12">
    <div class="max-w-7xl mx-auto px-2 py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div>
          <h3 class="font-bold text-lg mb-4 text-orange-400">顧客服務</h3>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="#" class="hover:text-white transition">常見問題</a></li>
            <li><a href="#" class="hover:text-white transition">送貨方式</a></li>
            <li><a href="#" class="hover:text-white transition">付款方式</a></li>
            <li><a href="#" class="hover:text-white transition">退換貨政策</a></li>
            <li><a href="#" class="hover:text-white transition">聯絡我們</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-lg mb-4 text-orange-400">關於 OHYA2.0</h3>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="#" class="hover:text-white transition">品牌介紹</a></li>
            <li><a href="#" class="hover:text-white transition">會員優惠</a></li>
            <li><a href="#" class="hover:text-white transition">積分計劃</a></li>
            <li><a href="#" class="hover:text-white transition">隱私政策</a></li>
            <li><a href="#" class="hover:text-white transition">使用條款</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-lg mb-4 text-orange-400">男士護理指南</h3>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="#" class="hover:text-white transition">新手入門</a></li>
            <li><a href="#" class="hover:text-white transition">產品選擇</a></li>
            <li><a href="#" class="hover:text-white transition">保養方法</a></li>
            <li><a href="#" class="hover:text-white transition">清潔技巧</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-lg mb-4 text-orange-400">聯絡我們</h3>
          <ul class="space-y-2 text-sm text-gray-400">
            <li>📧 info@ohya2.0.com</li>
            <li>📞 +852 1234 5678</li>
            <li>⏰ 星期一至日 10:00-20:00</li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm text-gray-500">
        <p>© 2025 OHYA2.0 版權所有 | 18歲以下人士禁止瀏覽</p>
        <p class="mt-1">本網站銷售之產品僅供成年人士使用，請根據個人需要選擇合適產品</p>
      </div>
    </div>
  </footer>

  <script>
    function verifyAge(isAdult) {
      if (isAdult) {
        document.getElementById('ageModal').classList.add('hidden');
        localStorage.setItem('ageVerified', 'true');
      } else {
        window.location.href = 'https://www.google.com.hk/';
      }
    }
    if (!localStorage.getItem('ageVerified')) {
      document.getElementById('ageModal').classList.remove('hidden');
    }
    function addToCart(btn) {
      const productId = btn.dataset.productId;
      const countEl = document.getElementById('cart-count');
      const current = parseInt(countEl.textContent);
      countEl.textContent = current + 1;
      alert('已加入購物車！');
    }
  </script>
</body>
</html>
