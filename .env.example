# Environment
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
# For Vercel Postgres / Supabase / Neon / etc.
DATABASE_URL=postgresql://username:password@localhost:5432/mzakka_ecommerce

# Session
SESSION_SECRET=your-random-secret-key-change-me-in-production

# CORS allowlist (comma-separated)
CORS_ALLOWED_ORIGINS=

# CSP mode: report|enforce
CSP_MODE=report
# CSP report endpoint path
CSP_REPORT_PATH=/csp-report

# ShipAny Logistics Integration (optional)
SHIPANY_API_KEY=
SHIPANY_WEBHOOK_SECRET=
SHIPANY_WEBHOOK_ALLOWED_IPS=
SHIPANY_API_URL=https://api.shipany.com/v1
SHIPANY_SENDER_NAME=
SHIPANY_SENDER_PHONE=
SHIPANY_SENDER_ADDRESS=
