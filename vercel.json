{
  "version": 2,
  "functions": {
    "api/*.js": {
      "excludeFiles": [
        "node_modules/@img/**",
        "node_modules/sharp/vendor/**",
        "test/**",
        "docs/**",
        "frontend/**",
        "migrations/**",
        "scripts/**",
        "data/**",
        "*.md",
        "*.sql"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "installCommand": "npm install --omit=dev"
}
