{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build && cp -rf dist/* ..",
  "functions": {
    "api/index.js": {}
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/test/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
